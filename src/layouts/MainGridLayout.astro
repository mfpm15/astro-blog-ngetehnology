---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import SpineModel from "@components/widget/SpineModel.astro";
import Live2DWidget from "@components/widget/Live2DWidget.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import FullscreenWallpaper from "../components/misc/FullscreenWallpaper.astro";
import IconifyLoader from "../components/misc/IconifyLoader.astro";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TypewriterText from "../components/TypewriterText.astro";
import FloatingTOC from "../components/widget/FloatingTOC.astro";
import { siteConfig, sidebarLayoutConfig, live2dModelConfig } from "../config";
import {
  BANNER_HEIGHT_EXTEND,
  HERO_HEIGHT_HOME_DESKTOP,
  HERO_HEIGHT_HOME_MOBILE,
  HERO_HEIGHT_HOME_TABLET,
  HERO_HEIGHT_INNER,
  HERO_HEIGHT_INNER_MOBILE,
  MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import { widgetManager } from "../utils/widget-manager";
import Layout from "./Layout.astro";

interface Props {
  title?: string;
  banner?: string;
  description?: string;
  lang?: string;
  setOGTypeArticle?: boolean;
  postSlug?: string;
  headings?: MarkdownHeading[];
}

const getBackgroundImages = () => {
  const bgSrc = siteConfig.backgroundWallpaper.src;

  if (
    typeof bgSrc === "object" &&
    bgSrc !== null &&
    !Array.isArray(bgSrc) &&
    ("desktop" in bgSrc || "mobile" in bgSrc)
  ) {
    return {
      desktop: bgSrc.desktop || bgSrc.mobile || "",
      mobile: bgSrc.mobile || bgSrc.desktop || "",
    };
  }

  return {
    desktop: bgSrc,
    mobile: bgSrc,
  };
};

const backgroundImages = getBackgroundImages();

const {
  title,
  banner,
  description,
  lang,
  setOGTypeArticle,
  postSlug,
  headings = [],
} = Astro.props;

const customHeroImage = typeof banner === "string" && banner.trim() ? banner.trim() : "";
const heroImages =
  customHeroImage !== ""
    ? {
        desktop: customHeroImage,
        mobile: customHeroImage,
      }
    : backgroundImages;
const heroBasePath = postSlug ? `content/posts/${postSlug}` : "/";

const isBannerMode = siteConfig.backgroundWallpaper.mode === "banner";
const isOverlayMode = siteConfig.backgroundWallpaper.mode === "overlay";
const isBackgroundEnabled = siteConfig.backgroundWallpaper.enable;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
const heroMode = isBannerMode && isBackgroundEnabled ? (isHomePage ? "home" : "inner") : "none";

const wavesConfig = siteConfig.backgroundWallpaper.banner?.waves?.enable;
const wavesEnabledOnDesktop = typeof wavesConfig === "object" ? wavesConfig?.desktop : wavesConfig;
const wavesEnabledOnMobile = typeof wavesConfig === "object" ? wavesConfig?.mobile : wavesConfig;

const creditEnableConfig = siteConfig.backgroundWallpaper.banner?.credit?.enable;
const creditEnabledOnDesktop =
  typeof creditEnableConfig === "object" ? creditEnableConfig?.desktop : creditEnableConfig;
const creditEnabledOnMobile =
  typeof creditEnableConfig === "object" ? creditEnableConfig?.mobile : creditEnableConfig;

const creditTextConfig = siteConfig.backgroundWallpaper.banner?.credit?.text;
const creditTextDesktop = typeof creditTextConfig === "object" ? creditTextConfig?.desktop : creditTextConfig;
const creditTextMobile = typeof creditTextConfig === "object" ? creditTextConfig?.mobile : creditTextConfig;

const creditUrlConfig = siteConfig.backgroundWallpaper.banner?.credit?.url;
const creditUrlDesktop = typeof creditUrlConfig === "object" ? creditUrlConfig?.desktop : creditUrlConfig;
const creditUrlMobile = typeof creditUrlConfig === "object" ? creditUrlConfig?.mobile : creditUrlConfig;

const homeText = siteConfig.backgroundWallpaper.banner?.homeText;
const renderHomeText = Boolean(homeText);
const showHomeText = heroMode === "home" && Boolean(homeText?.enable);
const shouldEnableTransparency = isOverlayMode && isBackgroundEnabled;
const transparentClass = shouldEnableTransparency ? "wallpaper-transparent" : "";

const globalSidebarEnabled = sidebarLayoutConfig.enable;
const sidebarPosition = sidebarLayoutConfig.position || "left";
const mobileShowSidebar = globalSidebarEnabled && widgetManager.shouldShowSidebar("mobile");
const tabletShowSidebar = globalSidebarEnabled && widgetManager.shouldShowSidebar("tablet");
const desktopShowSidebar = globalSidebarEnabled && widgetManager.shouldShowSidebar("desktop");

const gridCols = `
  grid-cols-1
  ${tabletShowSidebar ? (sidebarPosition === "right" ? "md:grid-cols-[1fr_17.5rem]" : "md:grid-cols-[17.5rem_1fr]") : "md:grid-cols-1"}
  ${desktopShowSidebar ? (sidebarPosition === "right" ? "lg:grid-cols-[1fr_17.5rem]" : "lg:grid-cols-[17.5rem_1fr]") : "lg:grid-cols-1"}
`
  .trim()
  .replace(/\s+/g, " ");

const sidebarClass = `
  onload-animation row-start-2 row-end-3 w-full
  ${mobileShowSidebar ? "block" : "hidden"}
  ${tabletShowSidebar ? `md:block md:row-start-1 md:row-end-2 md:max-w-[17.5rem] ${sidebarPosition === "right" ? "md:col-start-2 md:col-end-3" : "md:col-start-1 md:col-end-2"}` : "md:hidden"}
  ${desktopShowSidebar ? `lg:block lg:row-start-1 lg:row-end-2 lg:max-w-[17.5rem] ${sidebarPosition === "right" ? "lg:col-start-2 lg:col-end-3" : "lg:col-start-1 lg:col-end-2"}` : "lg:hidden"}
`
  .trim()
  .replace(/\s+/g, " ");

const mainContentClass = `
  transition-swup-fade min-w-0 overflow-hidden
  ${tabletShowSidebar ? `${sidebarPosition === "right" ? "md:col-start-1 md:col-end-2" : "md:col-start-2 md:col-end-3"}` : "md:col-span-1"}
  ${desktopShowSidebar ? `${sidebarPosition === "right" ? "lg:col-start-1 lg:col-end-2" : "lg:col-start-2 lg:col-end-3"}` : "lg:col-span-1"}
`
  .trim()
  .replace(/\s+/g, " ");
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle} postSlug={postSlug}>
  {
    isOverlayMode && isBackgroundEnabled && (
      <FullscreenWallpaper
        config={{
          enable: isBackgroundEnabled,
          src: {
            desktop: typeof backgroundImages.desktop === "string" ? backgroundImages.desktop : "",
            mobile: typeof backgroundImages.mobile === "string" ? backgroundImages.mobile : "",
          },
          position: siteConfig.backgroundWallpaper.position,
          zIndex: siteConfig.backgroundWallpaper.overlay?.zIndex,
          opacity: siteConfig.backgroundWallpaper.overlay?.opacity,
          blur: siteConfig.backgroundWallpaper.overlay?.blur,
        }}
      />
    )
  }

  <IconifyLoader />

  {
    shouldEnableTransparency && (
      <script>
        document.body.classList.add("wallpaper-transparent");
      </script>
    )
  }

  <slot slot="head" name="head" />

  <div id="top-row" class="pointer-events-none fixed inset-x-0 top-0 z-[120] transition-all duration-300">
    <div id="navbar-wrapper" class="pointer-events-auto mx-auto w-full max-w-[var(--page-width)] px-3 md:px-4">
      <Navbar />
    </div>
  </div>

  {
    heroMode !== "none" && (
      <section id="banner-wrapper" data-hero-mode={heroMode} class="absolute inset-x-0 z-10 overflow-hidden">
        <div class="relative h-full w-full">
          <ImageWrapper
            alt="Mobile background image of the blog"
            class="hero-image block h-full w-full object-cover lg:hidden"
            src={typeof heroImages.mobile === "string" ? heroImages.mobile : ""}
            position={siteConfig.backgroundWallpaper.position}
            basePath={heroBasePath}
            width={900}
            height={1176}
            loading="eager"
            decoding="async"
            fetchpriority={heroMode === "home" ? "high" : "auto"}
            sizes="100vw"
          />
          <ImageWrapper
            id="banner"
            alt="Desktop background image of the blog"
            class="hero-image hidden h-full w-full object-cover lg:block"
            src={typeof heroImages.desktop === "string" ? heroImages.desktop : ""}
            position={siteConfig.backgroundWallpaper.position}
            basePath={heroBasePath}
            width={1600}
            height={911}
            loading="eager"
            decoding="async"
            fetchpriority={heroMode === "home" ? "high" : "auto"}
            sizes="100vw"
          />
          <div class="hero-overlay absolute inset-0"></div>
        </div>

        {
          renderHomeText && (
            <div class:list={["banner-text-overlay absolute inset-0 z-20 flex items-center justify-center", { hidden: !showHomeText }]}>
              <div class="mx-auto flex w-[min(90%,56rem)] flex-col items-center text-center">
                {
                  homeText?.title && (
                    <h1 class="banner-title text-balance text-4xl font-bold text-white md:text-6xl lg:text-7xl">
                      {homeText.title}
                    </h1>
                  )
                }
                {
                  homeText?.subtitle && (
                    <div class="banner-subtitle mt-4 text-balance text-base text-white/90 md:text-xl lg:text-2xl">
                      {
                        homeText.typewriter?.enable ? (
                          <TypewriterText
                            text={homeText.subtitle}
                            speed={homeText.typewriter.speed}
                            deleteSpeed={homeText.typewriter.deleteSpeed}
                            pauseTime={homeText.typewriter.pauseTime}
                          />
                        ) : Array.isArray(homeText.subtitle) ? (
                          homeText.subtitle[0]
                        ) : (
                          homeText.subtitle
                        )
                      }
                    </div>
                  )
                }
              </div>
            </div>
          )
        }

        {
          (wavesEnabledOnDesktop || wavesEnabledOnMobile) && (
            <div
              id="header-waves"
              class:list={[
                "waves absolute inset-x-0 bottom-0",
                !wavesEnabledOnMobile && "hidden",
                !wavesEnabledOnDesktop && "md:hidden",
                wavesEnabledOnDesktop && "md:block",
              ]}
            >
              <svg
                class="h-full w-full"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                viewBox="0 20 150 32"
                preserveAspectRatio="none"
                shape-rendering="auto"
              >
                <defs>
                  <path
                    id="gentle-wave"
                    d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v48h-352z"
                  ></path>
                </defs>
                <g class="parallax">
                  <use xlink:href="#gentle-wave" x="48" y="0" class="opacity-25 fill-[var(--page-bg)]"></use>
                  <use xlink:href="#gentle-wave" x="48" y="3" class="opacity-50 fill-[var(--page-bg)]"></use>
                  <use xlink:href="#gentle-wave" x="48" y="5" class="opacity-75 fill-[var(--page-bg)]"></use>
                  <use xlink:href="#gentle-wave" x="48" y="7" class="fill-[var(--page-bg)]"></use>
                </g>
              </svg>
            </div>
          )
        }
      </section>
    )
  }

  <div id="content-shell" data-hero-mode={heroMode} class:list={["absolute inset-x-0 z-30 pointer-events-none", transparentClass]}>
    <div class="pointer-events-auto relative mx-auto max-w-[var(--page-width)]">
      <div id="main-grid" class:list={["mx-auto grid gap-4 px-2 md:px-4", gridCols]}>
        {
          heroMode !== "none" &&
            creditEnabledOnDesktop && (
              <a
                href={creditUrlDesktop || "#"}
                id="banner-credit-desktop"
                target={creditUrlDesktop ? "_blank" : "_self"}
                rel={creditUrlDesktop ? "noopener" : undefined}
                aria-label="Visit image source"
                class:list={[
                  "group absolute right-4 top-0 hidden -translate-y-[3.25rem] items-center gap-2 rounded-full bg-black/60 px-3 py-2 text-xs text-white/80 transition hover:bg-black/75 md:flex",
                  { "pr-9": Boolean(creditUrlDesktop) },
                ]}
              >
                <Icon class="text-base" name="material-symbols:copyright-outline-rounded" />
                <span>{creditTextDesktop}</span>
                {
                  creditUrlDesktop && (
                    <Icon
                      class="absolute right-4 text-[0.75rem] text-[oklch(0.75_0.14_var(--hue))] opacity-0 transition group-hover:opacity-100"
                      name="fa6-solid:arrow-up-right-from-square"
                    />
                  )
                }
              </a>
            )
        }

        {
          heroMode !== "none" &&
            creditEnabledOnMobile && (
              <a
                href={creditUrlMobile || "#"}
                id="banner-credit-mobile"
                target={creditUrlMobile ? "_blank" : "_self"}
                rel={creditUrlMobile ? "noopener" : undefined}
                aria-label="Visit image source"
                class:list={[
                  "group absolute right-4 top-0 flex -translate-y-[3.25rem] items-center gap-2 rounded-full bg-black/60 px-3 py-2 text-xs text-white/80 transition hover:bg-black/75 md:hidden",
                  { "pr-9": Boolean(creditUrlMobile) },
                ]}
              >
                <Icon class="text-base" name="material-symbols:copyright-outline-rounded" />
                <span>{creditTextMobile}</span>
                {
                  creditUrlMobile && (
                    <Icon
                      class="absolute right-4 text-[0.75rem] text-[oklch(0.75_0.14_var(--hue))] opacity-0 transition group-hover:opacity-100"
                      name="fa6-solid:arrow-up-right-from-square"
                    />
                  )
                }
              </a>
            )
        }

        {
          (mobileShowSidebar || tabletShowSidebar || desktopShowSidebar) && (
            <SideBar class={`${sidebarClass} ${transparentClass}`} headings={headings} />
          )
        }

        <main id="swup-container" class={mainContentClass}>
          <div id="content-wrapper" class="onload-animation transition-leaving">
            <slot />
          </div>
        </main>

        <div class="footer onload-animation md:col-span-2">
          <Footer />
        </div>
      </div>

      <BackToTop />
      <SpineModel />
      {live2dModelConfig.enable && <Live2DWidget config={live2dModelConfig} />}
    </div>
  </div>

  {siteConfig.toc.enable && <FloatingTOC headings={headings} />}
  {!siteConfig.toc.enable && <div id="toc"></div>}
</Layout>

<style
  define:vars={{
    heroHeightHomeDesktop: `${HERO_HEIGHT_HOME_DESKTOP}vh`,
    heroHeightHomeTablet: `${HERO_HEIGHT_HOME_TABLET}vh`,
    heroHeightHomeMobile: `${HERO_HEIGHT_HOME_MOBILE}vh`,
    heroHeightInnerDesktop: `${HERO_HEIGHT_INNER}rem`,
    heroHeightInnerMobile: `${HERO_HEIGHT_INNER_MOBILE}rem`,
    heroExtend: `${BANNER_HEIGHT_EXTEND}vh`,
    heroOverlap: `${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem`,
  }}
>
  :global(:root) {
    --hero-height-home: var(--heroHeightHomeDesktop);
    --hero-height-inner: var(--heroHeightInnerDesktop);
    --hero-extend: var(--heroExtend);
    --hero-overlap: var(--heroOverlap);
  }

  @media (max-width: 1024px) {
    :global(:root) {
      --hero-height-home: var(--heroHeightHomeTablet);
    }
  }

  @media (max-width: 768px) {
    :global(:root) {
      --hero-height-home: var(--heroHeightHomeMobile);
      --hero-height-inner: var(--heroHeightInnerMobile);
    }
  }

  #banner-wrapper[data-hero-mode="home"] {
    top: calc(-1 * var(--hero-extend));
    height: calc(var(--hero-height-home) + var(--hero-extend));
  }

  #banner-wrapper[data-hero-mode="inner"] {
    top: -1.5rem;
    height: calc(var(--hero-height-inner) + 3.5rem);
  }

  #content-shell[data-hero-mode="home"] {
    top: calc(var(--hero-height-home) - var(--hero-overlap));
    min-height: calc(100vh - (var(--hero-height-home) - var(--hero-overlap)));
  }

  #content-shell[data-hero-mode="inner"] {
    top: calc(var(--hero-height-inner) - 1.5rem);
    min-height: calc(100vh - (var(--hero-height-inner) - 1.5rem));
  }

  #content-shell[data-hero-mode="none"] {
    top: 5.5rem;
    min-height: calc(100vh - 5.5rem);
  }

  .hero-image {
    animation: heroScaleIn 2s ease-out both;
    transform: translateZ(0);
    will-change: transform;
  }

  .hero-overlay {
    background:
      linear-gradient(to bottom, rgba(9, 14, 24, 0.2), rgba(9, 14, 24, 0.45) 65%, rgba(9, 14, 24, 0.72)),
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.14), transparent 36%);
  }

  #banner-wrapper[data-hero-mode="inner"] .hero-overlay {
    background:
      linear-gradient(to bottom, rgba(9, 14, 24, 0.18), rgba(9, 14, 24, 0.42) 52%, rgba(9, 14, 24, 0.68)),
      linear-gradient(to right, rgba(9, 14, 24, 0.2), rgba(9, 14, 24, 0.06));
  }

  .banner-text-overlay {
    padding: clamp(1.5rem, 4vw, 3rem);
    text-align: center;
  }

  .banner-title {
    text-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
  }

  .banner-subtitle {
    text-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .waves {
    height: min(16vh, 9rem);
    min-height: 4rem;
  }

  @keyframes heroScaleIn {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image {
      animation: none;
      transform: none;
    }
  }
</style>

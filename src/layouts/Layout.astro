function setClickOutsideToClose(panel: string, ignores: string[]) {
	document.addEventListener("click", event => {
		let panelDom = document.getElementById(panel);
		let tDom = event.target;
		if (!panelDom) return;
		if (!(tDom instanceof Node)) return;		// Ensure the event target is an HTML Node
		for (let ig of ignores) {
			let ie = document.getElementById(ig)
			if (ie == tDom || (ie?.contains(tDom))) {
				return;
			}
		}
		panelDom.classList.add("float-panel-closed");
	});
}
setClickOutsideToClose("display-setting", ["display-setting", "display-settings-switch"])
setClickOutsideToClose("nav-menu-panel", ["nav-menu-panel", "nav-menu-switch"])
setClickOutsideToClose("search-panel", ["search-panel", "search-bar", "search-switch"])
setClickOutsideToClose("language-menu-panel", ["language-menu-panel", "language-menu-switch"])


function loadTheme() {
	const theme = getStoredTheme()
	setTheme(theme)
}

function loadHue() {
	setHue(getHue())
}

function initCustomScrollbar() {
	// KaTeX: wrap display blocks so they use the native horizontal scrollbar.
	const katexElements = document.querySelectorAll('.katex-display:not([data-scrollbar-initialized])') as NodeListOf<HTMLElement>;
	katexElements.forEach(element => {
		if (!element.parentNode) return;

		const container = document.createElement('div');
		container.className = 'katex-display-container';
		element.parentNode.insertBefore(container, element);
		container.appendChild(element);

		// Native scrollbar (no custom overlay).
		container.style.cssText = `
			overflow-x: auto;
		`;

		element.setAttribute('data-scrollbar-initialized', 'true');
	});
}

function showBanner() {
	const isBannerMode = siteConfig.backgroundWallpaper.mode === "banner";
	if (!siteConfig.backgroundWallpaper.enable || !isBannerMode) return;
	const heroEngine = (window as any).__ngetehHeroEngine;

	// Batch DOM updates into rAF.
	requestAnimationFrame(() => {
		// Handle single image banner (desktop)
		const banner = document.getElementById('banner');
		if (banner) {
			banner.classList.remove('opacity-0', 'scale-105');
		}

		// Handle single image banner (mobile)
		const mobileBanner = document.getElementById('banner-mobile');
		if (mobileBanner) {
			mobileBanner.classList.remove('opacity-0', 'scale-105');
			mobileBanner.classList.add('opacity-100');
		}

		heroEngine?.sync?.({
			route: window.location.pathname,
			phase: 'show-banner',
			isHomeRoute: pathsEqual(window.location.pathname, url('/')),
			forceRestart: true,
		});
	});
}

// Carousel has been removed.





function getShellRouteKind(nextUrl: string) {
	const resolvedUrl = new URL(nextUrl, window.location.origin);
	const pathname = resolvedUrl.pathname;

	if (pathsEqual(pathname, url('/'))) {
		return 'home';
	}

	if (pathname.startsWith('/posts/')) {
		return 'post';
	}

	if (pathname === '/about/' || pathname === '/friends/' || pathname === '/rss/') {
		return 'reading';
	}

	return 'utility';
}

function syncBannerPostMeta(routeKind: string, phase: string) {
	const overlay = document.getElementById('banner-post-meta-overlay');
	if (!overlay) return;

	const setActive = (active: boolean) => {
		overlay.setAttribute('data-active', active ? 'true' : 'false');
		overlay.setAttribute('aria-hidden', (!active).toString());
	};

	const clearText = () => {
		const titleEl = overlay.querySelector('[data-banner-post-title]');
		const publishedEl = overlay.querySelector('[data-banner-post-published]');
		const updatedEl = overlay.querySelector('[data-banner-post-updated]');
		const wordsEl = overlay.querySelector('[data-banner-post-words]');
		const minutesEl = overlay.querySelector('[data-banner-post-minutes]');

		if (titleEl) titleEl.textContent = '';
		if (publishedEl) publishedEl.textContent = '';
		if (updatedEl) updatedEl.textContent = '';
		if (wordsEl) wordsEl.textContent = '';
		if (minutesEl) minutesEl.textContent = '';

		overlay.querySelectorAll('[data-banner-post-item]').forEach((item) => {
			if (item instanceof HTMLElement) {
				item.setAttribute('data-visible', 'false');
			}
		});
	};

	// Never show during the outgoing transition. Wait for page:view when the new
	// page content (meta carrier) is already in the DOM.
	if (phase === 'visit:start') {
		setActive(false);
		return;
	}

	if (routeKind !== 'post') {
		setActive(false);
		return;
	}

	const carrier = document.querySelector('[data-post-hero-meta="true"]');
	if (!(carrier instanceof HTMLElement)) {
		setActive(false);
		return;
	}

	const title = carrier.dataset.title || '';
	const published = carrier.dataset.published || '';
	const updated = carrier.dataset.updated || '';
	const words = carrier.dataset.words || '';
	const minutes = carrier.dataset.minutes || '';

	if (!title || !published) {
		clearText();
		setActive(false);
		return;
	}

	const titleEl = overlay.querySelector('[data-banner-post-title]');
	const publishedEl = overlay.querySelector('[data-banner-post-published]');
	if (titleEl) titleEl.textContent = title;
	if (publishedEl) publishedEl.textContent = published;

	const applyMetaItem = (key: string, value: string, selector: string) => {
		const wrapper = overlay.querySelector(`[data-banner-post-item="${key}"]`);
		const valueEl = overlay.querySelector(selector);
		if (wrapper instanceof HTMLElement) {
			wrapper.setAttribute('data-visible', value ? 'true' : 'false');
		}
		if (valueEl) {
			valueEl.textContent = value || '';
		}
	};

	applyMetaItem('updated', updated, '[data-banner-post-updated]');
	applyMetaItem('words', words, '[data-banner-post-words]');
	applyMetaItem('minutes', minutes, '[data-banner-post-minutes]');

	setActive(true);
}

function syncShellRouteState(nextUrl: string, phase: string = 'manual') {
	const routeKind = getShellRouteKind(nextUrl);
	const isHomeRoute = routeKind === 'home';
	const bodyElement = document.body;
	const navbarElement = document.getElementById('navbar');
	const bannerWrapper = document.getElementById('banner-wrapper');
	const contentShell = document.getElementById('content-shell');
	const bannerTextOverlay = document.querySelector('.banner-home-text-overlay');
	const nextHeroMode = bannerWrapper ? (isHomeRoute ? 'home' : 'inner') : 'none';
	const heroEngine = (window as any).__ngetehHeroEngine;

	bodyElement.classList.toggle('is-home', isHomeRoute);
	navbarElement?.setAttribute('data-is-home', isHomeRoute.toString());
	if (bannerWrapper) {
		bannerWrapper.setAttribute('data-hero-mode', nextHeroMode);
		bannerWrapper.setAttribute('data-page-kind', routeKind);
	}
	if (contentShell) {
		contentShell.setAttribute('data-hero-mode', nextHeroMode);
		contentShell.setAttribute('data-page-kind', routeKind);
	}
	if (bannerTextOverlay) {
		bannerTextOverlay.classList.toggle('hidden', !isHomeRoute);
		bannerTextOverlay.setAttribute('aria-hidden', (!isHomeRoute).toString());
	}

	syncBannerPostMeta(routeKind, phase);

	heroEngine?.sync?.({
		route: nextUrl,
		phase,
		isHomeRoute,
	});
}

const homeHeroRestartWindow = window as Window & {
	__ngetehRestartHomeHero?: () => void;
	__ngetehHomeHeroRestartBound?: boolean;
	__ngetehHomeHeroRestartRafA?: number | null;
	__ngetehHomeHeroRestartRafB?: number | null;
	__ngetehTypewriterInit?: (options?: { resetText?: boolean }) => void;
};

function runHomeHeroRestart() {
	if (!pathsEqual(window.location.pathname, url('/'))) {
		return;
	}

	const heroEngine = (window as any).__ngetehHeroEngine;
	homeHeroRestartWindow.__ngetehTypewriterInit?.({ resetText: true });
	heroEngine?.sync?.({
		route: window.location.pathname,
		phase: 'page:view',
		isHomeRoute: true,
		forceRestart: true,
	});
}

function queueHomeHeroRestart() {
	if (!pathsEqual(window.location.pathname, url('/'))) {
		return;
	}

	if (homeHeroRestartWindow.__ngetehHomeHeroRestartRafA !== null && homeHeroRestartWindow.__ngetehHomeHeroRestartRafA !== undefined) {
		cancelAnimationFrame(homeHeroRestartWindow.__ngetehHomeHeroRestartRafA);
	}
	if (homeHeroRestartWindow.__ngetehHomeHeroRestartRafB !== null && homeHeroRestartWindow.__ngetehHomeHeroRestartRafB !== undefined) {
		cancelAnimationFrame(homeHeroRestartWindow.__ngetehHomeHeroRestartRafB);
	}

	homeHeroRestartWindow.__ngetehHomeHeroRestartRafA = requestAnimationFrame(() => {
		homeHeroRestartWindow.__ngetehHomeHeroRestartRafA = null;
		homeHeroRestartWindow.__ngetehHomeHeroRestartRafB = requestAnimationFrame(() => {
			homeHeroRestartWindow.__ngetehHomeHeroRestartRafB = null;
			runHomeHeroRestart();
		});
	});
}

function bindHomeHeroRestart() {
	if (homeHeroRestartWindow.__ngetehHomeHeroRestartBound) {
		return;
	}

	homeHeroRestartWindow.__ngetehHomeHeroRestartBound = true;
	homeHeroRestartWindow.__ngetehRestartHomeHero = () => {
		queueHomeHeroRestart();
	};

	document.addEventListener('swup:page:view', queueHomeHeroRestart);
	document.addEventListener('swup:content:replace', queueHomeHeroRestart);
	window.addEventListener('pageshow', () => {
		queueHomeHeroRestart();
	});
	document.addEventListener(
		'click',
		(event) => {
			const target = event.target;
			if (!(target instanceof Element)) {
				return;
			}

			const anchor = target.closest('a[href]');
			if (!(anchor instanceof HTMLAnchorElement)) {
				return;
			}

			if (anchor.target === '_blank' || anchor.hasAttribute('download')) {
				return;
			}

			const href = anchor.getAttribute('href') || '';
			if (!href || href.startsWith('#')) {
				return;
			}

			const nextUrl = new URL(anchor.href, window.location.origin);
			if (!pathsEqual(nextUrl.pathname, url('/'))) {
				return;
			}

			queueHomeHeroRestart();
		},
		true,
	);
}

bindHomeHeroRestart();

const setup = () => {
	// TODO: temp solution to change the height of the banner
/*
	window.swup.hooks.on('animation:out:start', () => {
		const path = window.location.pathname
		const body = document.querySelector('body')
		if (path[path.length - 1] === '/' && !body.classList.contains('is-home')) {
			body.classList.add('is-home')
		} else if (path[path.length - 1] !== '/' && body.classList.contains('is-home')) {
			body.classList.remove('is-home')
		}
	})
*/
	window.swup.hooks.on('link:click', () => {
		// Remove the delay for the first time page load
		document.documentElement.style.setProperty('--content-delay', '0ms')

	})
	window.swup.hooks.on('content:replace', () => {
		// Re-init KaTeX containers to use the native scrollbar.
		initCustomScrollbar();

		const tocElement = document.querySelector('table-of-contents');
		if (tocElement && typeof (tocElement as any).init === 'function') {
			setTimeout(() => {
				(tocElement as any).init();
			}, 100);
		}
		
		// Mobile TOC needs to re-init on all pages:
		// Home shows a post list, inner pages show headings.
		if (typeof (window as any).mobileTOCInit === 'function') {
			setTimeout(() => {
				(window as any).mobileTOCInit();
			}, 100);
		}

		// Calendar: destroy/re-init to avoid stale Swup-cached nodes.
		if (typeof (window as any).__ngetehInitCalendar === 'function') {
			setTimeout(() => {
				(window as any).__ngetehInitCalendar({ force: true });
			}, 100);
		}
		
		
		
		// Re-init scroll detection for the semi-transparent navbar mode.
		const navbar = document.getElementById('navbar')
		if (navbar) {
		const transparentMode = null
			
			if (transparentMode === 'semifull') {
				// Rebind scroll listeners.
				if (typeof (window as any).initSemifullScrollDetection === 'function') {
					(window as any).initSemifullScrollDetection()
				}
			}
		}
	})
	window.swup.hooks.on('visit:start', (visit: {to: {url: string}}) => {
		syncShellRouteState(visit.to.url, 'visit:start')
		// change banner height immediately when a link is clicked
		const bodyElement = document.querySelector('body')
		const isHomePage = pathsEqual(visit.to.url, url('/'))
		
		if (isHomePage) {
			bodyElement!.classList.add('is-home');
		} else {
			bodyElement!.classList.remove('is-home');
		}

		// Control banner text visibility based on page
		const bannerTextOverlay = document.querySelector('.banner-home-text-overlay')
		if (bannerTextOverlay) {
			if (isHomePage) {
				bannerTextOverlay.classList.remove('hidden')
				bannerTextOverlay.setAttribute('aria-hidden', 'false')
			} else {
				bannerTextOverlay.classList.add('hidden')
				bannerTextOverlay.setAttribute('aria-hidden', 'true')
			}
		}

		// Control navbar transparency based on page
		const navbar = document.getElementById('navbar')
		if (navbar) {
			navbar.setAttribute('data-is-home', isHomePage.toString())
			
			const transparentMode = null
			if (transparentMode === 'semifull') {
				if (typeof window.initSemifullScrollDetection === 'function') {
					window.initSemifullScrollDetection()
				}
			}
		}

		// increase the page height during page transition to prevent the scrolling animation from jumping
		const heightExtend = document.getElementById('page-height-extend')
		if (heightExtend) {
			heightExtend.classList.remove('hidden')
		}

		// Hide the TOC briefly during transitions to avoid a flash while scrolling to top.
		const tocShell =
			document.querySelector('widget-layout[data-id="toc-widget"]') ||
			document.getElementById('toc-widget') ||
			document.querySelector('table-of-contents');
		if (tocShell) tocShell.classList.add('toc-not-ready');
	});
	window.swup.hooks.on('page:view', () => {
		syncShellRouteState(window.location.pathname, 'page:view')
		window.__ngetehRestartHomeHero?.()
		// hide the temp high element when the transition is done
		const heightExtend = document.getElementById('page-height-extend')
		if (heightExtend) {
			heightExtend.classList.remove('hidden')
		}
		
		// Ensure the page scrolls to top (especially after closing the mobile banner).
		window.scrollTo({
			top: 0,
			behavior: 'auto'
		});
		
		// Sync theme state to avoid code block rendering issues across transitions.
		const storedTheme = getStoredTheme();
		const isDark = storedTheme === 'dark' || (
			storedTheme === 'system' &&
			window.matchMedia('(prefers-color-scheme: dark)').matches
		);
		const expectedTheme = isDark ? 'github-dark' : 'github-light';
		const currentTheme = document.documentElement.getAttribute('data-theme');
		
		// If the theme does not match, force-apply it.
		if (currentTheme !== expectedTheme) {
			document.documentElement.setAttribute('data-theme', expectedTheme);
			// Trigger code block re-render.
			setTimeout(() => {
				window.dispatchEvent(new CustomEvent('theme-change'));
			}, 50);
		}

		// Calendar: force a clean re-init after navigation (Swup cache safety).
		if (typeof (window as any).__ngetehInitCalendar === 'function') {
			setTimeout(() => {
				(window as any).__ngetehInitCalendar({ force: true });
			}, 100);
		}
		
		// If this page has a comment container, notify the comment system that the page is ready.
		setTimeout(() => {
			if (document.getElementById('tcomment')) {
				// Dispatch a custom event to signal the page is fully loaded.
				const pageLoadedEvent = new CustomEvent('firefly:page:loaded', {
					detail: {
						path: window.location.pathname,
						timestamp: Date.now()
					}
				});
				document.dispatchEvent(pageLoadedEvent);
			}
		}, 300);
	});
	window.swup.hooks.on('visit:end', (_visit: {to: {url: string}}) => {
		setTimeout(() => {
			const heightExtend = document.getElementById('page-height-extend')
			if (heightExtend) {
				heightExtend.classList.add('hidden')
			}

			const tocShell =
				document.querySelector('widget-layout[data-id="toc-widget"]') ||
				document.getElementById('toc-widget') ||
				document.querySelector('table-of-contents');
			if (tocShell) tocShell.classList.remove('toc-not-ready');
        }, 200)
	});
}
if (window?.swup?.hooks) {
	setup()
} else {
	document.addEventListener('swup:enable', setup)
}

// BFCache / back-forward navigation: force a fresh calendar bind.
window.addEventListener('pageshow', (event) => {
	if (!event.persisted) return;
	if (typeof (window as any).__ngetehInitCalendar === 'function') {
		(window as any).__ngetehInitCalendar({ force: true });
	}
});

let backToTopBtn = document.getElementById('back-to-top-btn');
let tocShell: HTMLElement | null = null;
let navbar = document.getElementById('navbar-wrapper')

function resolveTocShell(): HTMLElement | null {
	const el =
		document.querySelector('widget-layout[data-id="toc-widget"]') ||
		document.getElementById('toc-widget') ||
		document.querySelector('table-of-contents');
	return el instanceof HTMLElement ? el : null;
}

// Throttle helper.
function throttle(func: Function, limit: number) {
	let inThrottle: boolean;
	return function(this: any) {
		const args = arguments;
		const context = this;
		if (!inThrottle) {
			func.apply(context, args);
			inThrottle = true;
			setTimeout(() => inThrottle = false, limit);
		}
	}
}

function scrollFunction() {
	const scrollTop = document.documentElement.scrollTop;
	const bannerWrapper = document.getElementById('banner-wrapper');
	const hasBanner = !!bannerWrapper;
	const bannerHeight = bannerWrapper?.offsetHeight || window.innerHeight * (BANNER_HEIGHT / 100);

	// Batch DOM updates into rAF to reduce layout thrash.
	requestAnimationFrame(() => {
		const navElement = document.getElementById('navbar');
		navElement?.classList.toggle('scrolled', scrollTop > 20);

		if (backToTopBtn) {
			if (scrollTop > bannerHeight) {
				backToTopBtn.classList.remove('hide')
			} else {
				backToTopBtn.classList.add('hide')
			}
		}

		if (hasBanner) {
			if (!tocShell || !document.contains(tocShell)) {
				tocShell = resolveTocShell();
			}
			if (tocShell) {
				if (scrollTop > bannerHeight) {
					tocShell.classList.remove('toc-hide')
				} else {
					tocShell.classList.add('toc-hide')
				}
			}
		}

	});
}

// Use throttle to keep scroll work cheap (~60fps target).
window.onscroll = throttle(scrollFunction, 16);
scrollFunction();

window.onresize = () => {
	// calculate the --banner-height-extend, which needs to be a multiple of 4 to avoid blurry text
	let offset = Math.floor(window.innerHeight * (BANNER_HEIGHT_EXTEND / 100));
	offset = offset - offset % 4;
	document.documentElement.style.setProperty('--banner-height-extend', `${offset}px`);
}

// Init banner and KaTeX containers on load.
if (document.readyState === 'loading') {
	document.addEventListener('DOMContentLoaded', () => {
		syncShellRouteState(window.location.pathname, 'initial');
		showBanner();
		initCustomScrollbar();
	});
} else {
	syncShellRouteState(window.location.pathname, 'initial');
	showBanner();
	initCustomScrollbar();
}

</script>


---
import MarkdownEditor from "@components/studio/MarkdownEditor.astro";
import JsonConfigEditor from "@components/studio/JsonConfigEditor.astro";
import StudioShell from "@components/studio/StudioShell.astro";
import fs from "node:fs/promises";
import path from "node:path";
import friendsData from "../../data/friends.json";

const aboutMarkdown = await fs.readFile(
  path.join(process.cwd(), "src", "content", "spec", "about.md"),
  "utf8"
);
const friendsMarkdown = await fs.readFile(
  path.join(process.cwd(), "src", "content", "spec", "friends.md"),
  "utf8"
);
---

<StudioShell title="Studio Pages" description="Konten halaman statis dan friend links.">
  <MarkdownEditor
    title="About Page"
    section="aboutPage"
    value={aboutMarkdown}
  />
  <MarkdownEditor
    title="Friends Page"
    section="friendsPage"
    value={friendsMarkdown}
  />
  <JsonConfigEditor
    title="Friends Links"
    section="friends"
    value={JSON.stringify(friendsData, null, 2)}
  />
</StudioShell>

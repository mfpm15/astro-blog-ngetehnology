import commentData from "../../data/comment.json";
import footerData from "../../data/footer.json";
import licenseData from "../../data/license.json";
import musicPlayerData from "../../data/music-player.json";
---

<StudioShell title="Studio Integrations" description="Konfigurasi fitur integrasi dan widget tambahan.">
  <IntegrationsManager
    comment={commentData}
    musicPlayer={musicPlayerData}
    license={licenseData}
    footer={footerData}
  />
</StudioShell>

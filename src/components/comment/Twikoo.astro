---
import { commentConfig } from "../../config/commentConfig";

interface Props {
  path: string;
}

const config = {
  ...commentConfig.twikoo,
  el: "#tcomment",
  path: Astro.props.path,
};
---

<div id="tcomment"></div>
<script is:inline src="/assets/js/firefly-twikoo-1.6.44.all.min.js"></script>
<script is:inline define:vars={{ config }}>
  // Get a stable path (remove the trailing slash except for root).
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  // Build config on demand so the path is always current.
  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  // Init Twikoo.
  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        commentEl.innerHTML = "";

        const dynamicConfig = createTwikooConfig();
        console.debug("[Twikoo] Initializing config:", dynamicConfig);

        twikoo
          .init(dynamicConfig)
          .then(() => {
            console.debug("[Twikoo] Initialized");
          })
          .catch((error) => {
            console.error("[Twikoo] Init failed:", error);
          });
      }
    } else {
      // If Twikoo is not loaded yet, retry shortly.
      setTimeout(initTwikoo, 500);
    }
  }

  // Init on page load.
  document.addEventListener("DOMContentLoaded", initTwikoo);

  // Re-init after Swup navigation.
  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(initTwikoo, 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(initTwikoo, 200);
        });
      }
    });
  }

  // Custom hook: when a page is fully ready.
  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.debug("[Twikoo] Re-initializing after firefly:page:loaded");
      initTwikoo();
    }
  });
</script>

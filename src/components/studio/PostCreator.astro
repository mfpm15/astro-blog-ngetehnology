---
const today = new Date().toISOString().slice(0, 10);

interface TaxonomyData {
  categories: string[];
  tags: string[];
}

interface Props {
  taxonomy: TaxonomyData;
}

const { taxonomy } = Astro.props;
---

<section class="grid gap-6 xl:grid-cols-[20rem_minmax(0,1fr)]">
  <aside class="space-y-6">
    <section class="card-base p-5">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-bold">Daftar Post</h2>
          <p class="text-50 mt-2 text-sm">
            Pilih artikel untuk diedit atau mulai tulisan baru.
          </p>
        </div>
        <button class="btn-regular rounded-xl px-4 py-2 text-sm font-semibold" id="post-new-btn" type="button">
          Post Baru
        </button>
      </div>

      <div class="mt-4">
        <input
          id="post-search"
          class="studio-input w-full"
          type="search"
          placeholder="Cari judul atau slug..."
        />
      </div>

      <div id="post-list-status" class="mt-4 text-sm text-50">Memuat daftar post...</div>
      <div id="post-list" class="mt-4 flex max-h-[36rem] flex-col gap-3 overflow-y-auto pr-1"></div>
    </section>

    <section class="card-base p-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold">Kategori & Tag</h2>
          <p class="text-50 mt-2 text-sm">
            Database lokal ini dipakai ulang saat membuat post.
          </p>
        </div>
        <button class="btn-plain rounded-xl px-4 py-2 text-sm font-semibold" id="taxonomy-save-btn" type="button">
          Simpan
        </button>
      </div>

      <div class="mt-5 space-y-5">
        <div>
          <label class="mb-2 block font-medium" for="taxonomy-category-input">Tambah kategori</label>
          <div class="flex gap-2">
            <input id="taxonomy-category-input" class="studio-input flex-1" type="text" placeholder="Contoh: Tutorial" />
            <button class="btn-regular rounded-xl px-4 py-2 text-sm font-semibold" id="taxonomy-category-add-btn" type="button">
              Tambah
            </button>
          </div>
          <div id="taxonomy-category-list" class="mt-3 flex flex-wrap gap-2"></div>
        </div>

        <div>
          <label class="mb-2 block font-medium" for="taxonomy-tag-input">Tambah tag</label>
          <div class="flex gap-2">
            <input id="taxonomy-tag-input" class="studio-input flex-1" type="text" placeholder="Contoh: Astro" />
            <button class="btn-regular rounded-xl px-4 py-2 text-sm font-semibold" id="taxonomy-tag-add-btn" type="button">
              Tambah
            </button>
          </div>
          <div id="taxonomy-tag-list" class="mt-3 flex flex-wrap gap-2"></div>
        </div>

        <p id="taxonomy-status" class="text-sm text-50"></p>
      </div>
    </section>
  </aside>

  <section class="card-base p-6">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div>
        <h2 class="text-xl font-bold" id="editor-title">Buat Post Baru</h2>
        <p class="text-50 mt-2">
          Slug dibuat otomatis dari judul. Ringkasan artikel juga dibuat otomatis dari isi tulisan.
        </p>
      </div>
      <span
        id="editor-mode-badge"
        class="rounded-full bg-[var(--btn-regular-bg)] px-3 py-1 text-xs font-semibold text-[var(--btn-content)]"
      >
        Mode Create
      </span>
    </div>

    <form id="post-form" class="grid gap-4 lg:grid-cols-2">
      <input type="hidden" name="originalSlug" value="" />
      <input type="hidden" name="category" value="" />
      <input type="hidden" name="tags" value="" />

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Judul</span>
        <input class="studio-input" type="text" name="title" required />
      </label>

      <div class="rounded-2xl border border-[var(--line-color)] bg-[var(--btn-plain-bg)]/60 p-4 lg:col-span-2">
        <div class="text-sm font-medium text-70">Slug otomatis</div>
        <div id="slug-preview" class="mt-2 text-sm text-50">-</div>
      </div>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Tanggal Publish</span>
        <input class="studio-input" type="date" name="published" value={today} required />
      </label>

      <div class="flex flex-col gap-2">
        <span class="font-medium">Kategori</span>
        <select class="studio-input" id="post-category-select">
          <option value="">Pilih kategori</option>
        </select>
      </div>

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Tambah kategori baru jika belum ada</span>
        <input class="studio-input" id="post-category-custom" type="text" placeholder="Kosongkan jika memakai kategori yang sudah ada" />
      </label>

      <div class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Tags</span>
        <div id="tag-options" class="flex flex-wrap gap-2"></div>
      </div>

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Tambah tag baru</span>
        <input class="studio-input" id="post-new-tags" type="text" placeholder="Pisahkan dengan koma jika lebih dari satu" />
      </label>

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Cover artikel</span>
        <input
          class="studio-input"
          type="text"
          name="image"
          placeholder="URL cover dari website atau kosongkan jika ingin pakai upload lokal"
        />
      </label>

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Upload cover lokal</span>
        <input class="studio-input" type="file" name="coverFile" accept="image/*" />
      </label>

      <div class="flex flex-wrap gap-4 lg:col-span-2">
        <label class="flex items-center gap-3">
          <input type="checkbox" name="draft" value="true" />
          <span>Simpan sebagai draft</span>
        </label>

        <label class="flex items-center gap-3">
          <input type="checkbox" name="pinned" value="true" />
          <span>Pin di daftar artikel</span>
        </label>
      </div>

      <label class="flex flex-col gap-2 lg:col-span-2">
        <span class="font-medium">Isi Artikel</span>
        <textarea class="studio-input min-h-[26rem] font-mono text-sm" name="content" required>## Pendahuluan

Tulis artikel Anda di sini.
</textarea>
      </label>

      <div class="flex flex-wrap items-center gap-3 lg:col-span-2">
        <button class="btn-regular rounded-xl px-5 py-3 font-semibold" id="post-submit-btn" type="submit">
          Simpan Post
        </button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="post-delete-btn" type="button" hidden>
          Hapus Post
        </button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="post-reset-btn" type="button">
          Reset Form
        </button>
        <p id="post-status" class="text-sm text-50"></p>
      </div>
    </form>
  </section>
</section>

<script is:inline define:vars={{ today, initialTaxonomy: taxonomy }}>
  const postForm = document.getElementById("post-form");
  const postStatus = document.getElementById("post-status");
  const postList = document.getElementById("post-list");
  const postListStatus = document.getElementById("post-list-status");
  const searchInput = document.getElementById("post-search");
  const newButton = document.getElementById("post-new-btn");
  const resetButton = document.getElementById("post-reset-btn");
  const deleteButton = document.getElementById("post-delete-btn");
  const editorTitle = document.getElementById("editor-title");
  const editorModeBadge = document.getElementById("editor-mode-badge");
  const submitButton = document.getElementById("post-submit-btn");
  const slugPreview = document.getElementById("slug-preview");
  const categorySelect = document.getElementById("post-category-select");
  const categoryCustomInput = document.getElementById("post-category-custom");
  const tagOptions = document.getElementById("tag-options");
  const newTagsInput = document.getElementById("post-new-tags");
  const taxonomyCategoryInput = document.getElementById("taxonomy-category-input");
  const taxonomyTagInput = document.getElementById("taxonomy-tag-input");
  const taxonomyCategoryList = document.getElementById("taxonomy-category-list");
  const taxonomyTagList = document.getElementById("taxonomy-tag-list");
  const taxonomyStatus = document.getElementById("taxonomy-status");

  const initialFormState = {
    title: "",
    originalSlug: "",
    published: today,
    category: "",
    tags: [],
    image: "",
    draft: false,
    pinned: false,
    content: "## Pendahuluan\n\nTulis artikel Anda di sini.\n",
  };

  let studioPosts = [];
  let activeSlug = "";
  let taxonomyState = {
    categories: [...(initialTaxonomy.categories || [])],
    tags: [...(initialTaxonomy.tags || [])],
  };
  let selectedTags = new Set();

  function slugify(value) {
    return value
      .normalize("NFKD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
      .replace(/-{2,}/g, "-");
  }

  function normalizeUnique(values) {
    return Array.from(
      new Set(
        values
          .map((value) => String(value || "").trim())
          .filter(Boolean),
      ),
    ).sort((a, b) => a.localeCompare(b));
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  function syncHiddenFields() {
    if (!postForm) return;
    const chosenCategory = categoryCustomInput?.value.trim() || categorySelect?.value || "";
    postForm.elements.category.value = chosenCategory;
    postForm.elements.tags.value = Array.from(selectedTags).join(", ");
  }

  function updateSlugPreview() {
    const title = postForm?.elements.title.value || "";
    const slug = slugify(title);
    slugPreview.textContent = slug ? `/posts/${slug}/` : "-";
  }

  function renderCategoryOptions(selected = "") {
    if (!categorySelect) return;
    const normalizedCategories = normalizeUnique(taxonomyState.categories);
    taxonomyState.categories = normalizedCategories;
    categorySelect.innerHTML =
      '<option value="">Pilih kategori</option>' +
      normalizedCategories
        .map((category) => `<option value="${escapeHtml(category)}">${escapeHtml(category)}</option>`)
        .join("");

    if (selected && normalizedCategories.includes(selected)) {
      categorySelect.value = selected;
      if (categoryCustomInput) categoryCustomInput.value = "";
    } else {
      categorySelect.value = "";
      if (categoryCustomInput) categoryCustomInput.value = selected;
    }
    syncHiddenFields();
  }

  function renderTagOptions() {
    if (!tagOptions) return;
    const normalizedTags = normalizeUnique(taxonomyState.tags);
    taxonomyState.tags = normalizedTags;
    tagOptions.innerHTML = normalizedTags
      .map((tag) => {
        const activeClass = selectedTags.has(tag)
          ? "border-[var(--primary)] bg-[var(--btn-regular-bg)] text-[var(--btn-content)]"
          : "border-[var(--line-color)] bg-[var(--card-bg)] text-70";
        return `
          <button
            type="button"
            class="studio-chip rounded-full border px-3 py-2 text-sm font-medium transition ${activeClass}"
            data-tag-option="${escapeHtml(tag)}"
          >
            ${escapeHtml(tag)}
          </button>
        `;
      })
      .join("");

    tagOptions.querySelectorAll("[data-tag-option]").forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.dataset.tagOption;
        if (!tag) return;
        if (selectedTags.has(tag)) {
          selectedTags.delete(tag);
        } else {
          selectedTags.add(tag);
        }
        syncHiddenFields();
        renderTagOptions();
      });
    });
  }

  function renderTaxonomyList(container, items, type) {
    if (!container) return;
    container.innerHTML = normalizeUnique(items)
      .map(
        (item) => `
          <button
            type="button"
            class="studio-taxonomy-item rounded-full border border-[var(--line-color)] bg-[var(--card-bg)] px-3 py-2 text-sm transition hover:border-[var(--primary)]"
            data-taxonomy-type="${type}"
            data-taxonomy-value="${escapeHtml(item)}"
          >
            ${escapeHtml(item)}
            <span class="ml-2 text-50">x</span>
          </button>
        `,
      )
      .join("");

    container.querySelectorAll("[data-taxonomy-value]").forEach((button) => {
      button.addEventListener("click", () => {
        const value = button.dataset.taxonomyValue;
        const targetType = button.dataset.taxonomyType;
        if (!value || !targetType) return;

        taxonomyState[targetType] = taxonomyState[targetType].filter((item) => item !== value);
        if (targetType === "tags") {
          selectedTags.delete(value);
          renderTagOptions();
        }
        if (targetType === "categories" && categorySelect?.value === value) {
          categorySelect.value = "";
        }
        renderTaxonomyPanels();
        syncHiddenFields();
      });
    });
  }

  function renderTaxonomyPanels() {
    renderCategoryOptions(postForm?.elements.category.value || categoryCustomInput?.value || "");
    renderTagOptions();
    renderTaxonomyList(taxonomyCategoryList, taxonomyState.categories, "categories");
    renderTaxonomyList(taxonomyTagList, taxonomyState.tags, "tags");
  }

  function addTaxonomyItem(type, rawValue) {
    const values = normalizeUnique(rawValue.split(","));
    if (values.length === 0) return;
    taxonomyState[type] = normalizeUnique([...taxonomyState[type], ...values]);
    if (type === "tags") {
      values.forEach((value) => selectedTags.add(value));
    }
    renderTaxonomyPanels();
    syncHiddenFields();
  }

  async function saveTaxonomy() {
    taxonomyStatus.textContent = "Menyimpan database kategori dan tag...";
    try {
      const response = await fetch("/api/studio/config/", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          section: "postTaxonomy",
          value: {
            categories: normalizeUnique(taxonomyState.categories),
            tags: normalizeUnique(taxonomyState.tags),
          },
        }),
      });
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || "Gagal menyimpan taxonomy.");
      }
      taxonomyStatus.textContent = "Database kategori dan tag tersimpan.";
    } catch (error) {
      taxonomyStatus.textContent = error.message;
    }
  }

  function applyFormState(payload) {
    if (!postForm) return;
    selectedTags = new Set(Array.isArray(payload.tags) ? payload.tags : []);

    postForm.elements.title.value = payload.title ?? "";
    postForm.elements.originalSlug.value = payload.originalSlug ?? "";
    postForm.elements.published.value = payload.published ?? "";
    postForm.elements.image.value = payload.image ?? "";
    postForm.elements.draft.checked = Boolean(payload.draft);
    postForm.elements.pinned.checked = Boolean(payload.pinned);
    postForm.elements.content.value = payload.content ?? "";
    postForm.elements.coverFile.value = "";

    renderCategoryOptions(payload.category ?? "");
    renderTagOptions();
    syncHiddenFields();
    updateSlugPreview();
  }

  function setCreateMode() {
    activeSlug = "";
    applyFormState(initialFormState);
    editorTitle.textContent = "Buat Post Baru";
    editorModeBadge.textContent = "Mode Create";
    submitButton.textContent = "Simpan Post";
    deleteButton.hidden = true;
    highlightActiveItem();
  }

  function setEditMode(post) {
    activeSlug = post.slug;
    applyFormState({
      ...post,
      originalSlug: post.slug,
      tags: Array.isArray(post.tags) ? post.tags : [],
    });
    editorTitle.textContent = `Edit Post: ${post.title}`;
    editorModeBadge.textContent = "Mode Update";
    submitButton.textContent = "Simpan Perubahan";
    deleteButton.hidden = false;
    highlightActiveItem();
  }

  function highlightActiveItem() {
    const items = postList?.querySelectorAll("[data-post-slug]");
    items?.forEach((item) => {
      const isActive = item.dataset.postSlug === activeSlug;
      item.classList.toggle("studio-post-item-active", isActive);
    });
  }

  function renderPostList() {
    if (!postList || !postListStatus) return;

    const keyword = (searchInput?.value || "").trim().toLowerCase();
    const filtered = studioPosts.filter((item) => {
      if (!keyword) return true;
      return (
        item.title.toLowerCase().includes(keyword) ||
        item.slug.toLowerCase().includes(keyword) ||
        (item.category || "").toLowerCase().includes(keyword)
      );
    });

    if (filtered.length === 0) {
      postList.innerHTML = "";
      postListStatus.textContent = keyword
        ? "Tidak ada post yang cocok dengan pencarian."
        : "Belum ada post.";
      return;
    }

    postListStatus.textContent = `${filtered.length} post tersedia.`;
    postList.innerHTML = filtered
      .map((item) => {
        const meta = [item.published, item.draft ? "Draft" : "Published"]
          .filter(Boolean)
          .join(" | ");
        return `
          <button type="button" class="studio-post-item w-full rounded-2xl border border-[var(--line-color)] p-4 text-left transition hover:border-[var(--primary)] hover:bg-[var(--btn-plain-bg-hover)]" data-post-slug="${item.slug}">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="font-semibold text-90">${escapeHtml(item.title)}</div>
                <div class="mt-1 text-xs text-50">${escapeHtml(item.slug)}</div>
              </div>
              ${item.draft ? '<span class="rounded-full bg-amber-500/15 px-2 py-1 text-[10px] font-semibold text-amber-600 dark:text-amber-300">DRAFT</span>' : ""}
            </div>
            <div class="mt-3 text-xs text-50">${escapeHtml(meta)}</div>
            ${item.category ? `<div class="mt-1 text-xs text-50">${escapeHtml(item.category)}</div>` : ""}
          </button>
        `;
      })
      .join("");

    postList.querySelectorAll("[data-post-slug]").forEach((button) => {
      button.addEventListener("click", async () => {
        const slug = button.dataset.postSlug;
        postStatus.textContent = "Memuat detail post...";
        try {
          const response = await fetch(`/api/studio/post/?slug=${encodeURIComponent(slug)}`);
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.error || "Gagal memuat detail post.");
          }
          setEditMode(result.item);
          postStatus.textContent = `Detail post "${result.item.slug}" dimuat.`;
        } catch (error) {
          postStatus.textContent = error.message;
        }
      });
    });

    highlightActiveItem();
  }

  async function refreshPostList() {
    if (!postListStatus) return;
    postListStatus.textContent = "Memuat daftar post...";
    try {
      const response = await fetch("/api/studio/posts/");
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || "Gagal mengambil daftar post.");
      }
      studioPosts = result.items || [];
      renderPostList();
    } catch (error) {
      postListStatus.textContent = error.message;
      if (postList) postList.innerHTML = "";
    }
  }

  searchInput?.addEventListener("input", renderPostList);

  newButton?.addEventListener("click", () => {
    setCreateMode();
    postStatus.textContent = "Siap membuat post baru.";
  });

  resetButton?.addEventListener("click", async () => {
    if (activeSlug) {
      try {
        const response = await fetch(`/api/studio/post/?slug=${encodeURIComponent(activeSlug)}`);
        const result = await response.json();
        if (!response.ok) {
          throw new Error(result.error || "Gagal memuat ulang post.");
        }
        setEditMode(result.item);
        postStatus.textContent = "Form dikembalikan ke data terakhir tersimpan.";
      } catch (error) {
        postStatus.textContent = error.message;
      }
      return;
    }
    setCreateMode();
    postStatus.textContent = "Form direset.";
  });

  deleteButton?.addEventListener("click", async () => {
    const slug = postForm?.elements.originalSlug.value || activeSlug;
    if (!slug) return;

    const confirmed = window.confirm(`Hapus post "${slug}"? Tindakan ini tidak bisa dibatalkan.`);
    if (!confirmed) return;

    postStatus.textContent = `Menghapus post "${slug}"...`;

    try {
      const response = await fetch("/api/studio/post/delete/", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ slug }),
      });
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || "Gagal menghapus post.");
      }
      setCreateMode();
      postStatus.textContent = `Post "${slug}" berhasil dihapus.`;
      await refreshPostList();
    } catch (error) {
      postStatus.textContent = error.message;
    }
  });

  postForm?.elements.title.addEventListener("input", updateSlugPreview);
  categorySelect?.addEventListener("change", () => {
    if (categorySelect.value && categoryCustomInput) {
      categoryCustomInput.value = "";
    }
    syncHiddenFields();
  });
  categoryCustomInput?.addEventListener("input", syncHiddenFields);
  newTagsInput?.addEventListener("change", () => {
    if (!newTagsInput.value.trim()) return;
    addTaxonomyItem("tags", newTagsInput.value);
    newTagsInput.value = "";
  });

  document.getElementById("taxonomy-category-add-btn")?.addEventListener("click", () => {
    if (!taxonomyCategoryInput?.value.trim()) return;
    addTaxonomyItem("categories", taxonomyCategoryInput.value);
    taxonomyCategoryInput.value = "";
    taxonomyStatus.textContent = "Kategori ditambahkan. Klik Simpan untuk menyimpan permanen.";
  });

  document.getElementById("taxonomy-tag-add-btn")?.addEventListener("click", () => {
    if (!taxonomyTagInput?.value.trim()) return;
    addTaxonomyItem("tags", taxonomyTagInput.value);
    taxonomyTagInput.value = "";
    taxonomyStatus.textContent = "Tag ditambahkan. Klik Simpan untuk menyimpan permanen.";
  });

  document.getElementById("taxonomy-save-btn")?.addEventListener("click", saveTaxonomy);

  if (postForm && postStatus) {
    postForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      syncHiddenFields();

      const formData = new FormData(postForm);
      const isUpdate = Boolean(formData.get("originalSlug"));
      const endpoint = isUpdate ? "/api/studio/post/update/" : "/api/studio/post/";

      postStatus.textContent = isUpdate ? "Menyimpan perubahan post..." : "Membuat post baru...";

      try {
        if (taxonomyState.categories.length || taxonomyState.tags.length) {
          await saveTaxonomy();
        }

        const response = await fetch(endpoint, {
          method: "POST",
          body: formData,
        });
        const result = await response.json();
        if (!response.ok) {
          throw new Error(result.error || "Gagal menyimpan post.");
        }

        postStatus.textContent = isUpdate
          ? `Post diperbarui: ${result.path}`
          : `Post dibuat: ${result.path}`;

        await refreshPostList();

        if (result.slug) {
          const detailResponse = await fetch(`/api/studio/post/?slug=${encodeURIComponent(result.slug)}`);
          const detail = await detailResponse.json();
          if (!detailResponse.ok) {
            throw new Error(detail.error || "Gagal memuat hasil simpan.");
          }
          setEditMode(detail.item);
        } else {
          setCreateMode();
        }
      } catch (error) {
        postStatus.textContent = error.message;
      }
    });
  }

  setCreateMode();
  renderTaxonomyPanels();
  refreshPostList();
</script>

<style>
  .studio-input {
    border: 1px solid color-mix(in oklab, var(--primary) 16%, transparent);
    border-radius: 1rem;
    background: var(--card-bg);
    padding: 0.875rem 1rem;
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease;
  }

  .studio-input:focus {
    outline: none;
    border-color: color-mix(in oklab, var(--primary) 50%, transparent);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 14%, transparent);
  }

  .studio-post-item-active {

---
interface NavItem {
  name: string;
  url: string;
  icon?: string;
  external?: boolean;
  children?: NavItem[];
}

interface SidebarComponent {
  type: string;
  enable: boolean;
  order: number;
  position: "top" | "sticky";
  class?: string;
  animationDelay?: number;
  configId?: string;
}

interface SidebarLayout {
  enable: boolean;
  position: "left" | "right";
  components: SidebarComponent[];
}

interface Props {
  navbarLinks: NavItem[];
  sidebarLayout: SidebarLayout;
}

const { navbarLinks, sidebarLayout } = Astro.props;
---

<section class="grid gap-6 xl:grid-cols-2">
  <section class="card-base p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-xl font-bold">Navbar</h2>
        <p class="text-50 mt-2">Tambah, edit, hapus, dan urutkan menu atas.</p>
      </div>
      <button class="btn-regular rounded-xl px-4 py-2 text-sm font-semibold" id="nav-add-btn" type="button">
        Menu Baru
      </button>
    </div>

    <div id="nav-list" class="mt-5 flex flex-col gap-3"></div>

    <form id="nav-form" class="mt-5 grid gap-4 md:grid-cols-2">
      <input type="hidden" name="index" value="" />

      <label class="flex flex-col gap-2">
        <span class="font-medium">Nama Menu</span>
        <input class="studio-input" type="text" name="name" required />
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">URL</span>
        <input class="studio-input" type="text" name="url" required />
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Icon</span>
        <input class="studio-input" type="text" name="icon" placeholder="material-symbols:home" />
      </label>

      <label class="flex items-center gap-3 pt-8">
        <input type="checkbox" name="external" value="true" />
        <span>Buka sebagai link eksternal</span>
      </label>

      <label class="flex flex-col gap-2 md:col-span-2">
        <span class="font-medium">Submenu</span>
        <textarea
          class="studio-input min-h-40 font-mono text-sm"
          name="childrenJson"
          placeholder='[{"name":"GitHub","url":"https://github.com","external":true}]'
        ></textarea>
      </label>

      <div class="flex flex-wrap gap-3 md:col-span-2">
        <button class="btn-regular rounded-xl px-5 py-3 font-semibold" type="submit">Simpan Menu</button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="nav-delete-btn" type="button" hidden>
          Hapus Menu
        </button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="nav-reset-btn" type="button">
          Reset
        </button>
        <p id="nav-status" class="text-sm text-50"></p>
      </div>
    </form>
  </section>

  <section class="card-base p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-xl font-bold">Sidebar</h2>
        <p class="text-50 mt-2">Kontrol layout sidebar dan widget yang tampil.</p>
      </div>
      <button class="btn-regular rounded-xl px-4 py-2 text-sm font-semibold" id="sidebar-add-btn" type="button">
        Widget Baru
      </button>
    </div>

    <form id="sidebar-layout-form" class="mt-5 grid gap-4 md:grid-cols-2">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="enable" value="true" />
        <span>Aktifkan sidebar</span>
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Posisi sidebar</span>
        <select class="studio-input" name="position">
          <option value="left">Kiri</option>
          <option value="right">Kanan</option>
        </select>
      </label>
    </form>

    <div id="sidebar-list" class="mt-5 flex flex-col gap-3"></div>

    <form id="sidebar-form" class="mt-5 grid gap-4 md:grid-cols-2">
      <input type="hidden" name="index" value="" />

      <label class="flex flex-col gap-2">
        <span class="font-medium">Tipe Widget</span>
        <select class="studio-input" name="type">
          <option value="profile">profile</option>
          <option value="announcement">announcement</option>
          <option value="categories">categories</option>
          <option value="tags">tags</option>
          <option value="toc">toc</option>
          <option value="advertisement">advertisement</option>
          <option value="calendar">calendar</option>
          <option value="site-stats">site-stats</option>
          <option value="music-player">music-player</option>
          <option value="custom">custom</option>
        </select>
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Posisi widget</span>
        <select class="studio-input" name="position">
          <option value="top">top</option>
          <option value="sticky">sticky</option>
        </select>
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Urutan</span>
        <input class="studio-input" type="number" min="1" name="order" value="1" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Animation Delay</span>
        <input class="studio-input" type="number" min="0" name="animationDelay" value="0" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Class</span>
        <input class="studio-input" type="text" name="className" />
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-medium">Config ID</span>
        <input class="studio-input" type="text" name="configId" />
      </label>

      <label class="flex items-center gap-3 md:col-span-2">
        <input type="checkbox" name="enable" value="true" checked />
        <span>Widget aktif</span>
      </label>

      <div class="flex flex-wrap gap-3 md:col-span-2">
        <button class="btn-regular rounded-xl px-5 py-3 font-semibold" type="submit">Simpan Widget</button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="sidebar-delete-btn" type="button" hidden>
          Hapus Widget
        </button>
        <button class="btn-plain rounded-xl px-5 py-3 font-semibold" id="sidebar-reset-btn" type="button">
          Reset
        </button>
        <button class="btn-regular rounded-xl px-5 py-3 font-semibold" id="sidebar-save-all-btn" type="button">
          Simpan Sidebar
        </button>
        <p id="sidebar-status" class="text-sm text-50"></p>
      </div>
    </form>
  </section>
</section>

<script is:inline define:vars={{ initialNavbarLinks: navbarLinks, initialSidebarLayout: sidebarLayout }}>
  const navList = document.getElementById("nav-list");
  const navForm = document.getElementById("nav-form");
  const navStatus = document.getElementById("nav-status");
  const navDeleteButton = document.getElementById("nav-delete-btn");
  const sidebarList = document.getElementById("sidebar-list");
  const sidebarForm = document.getElementById("sidebar-form");
  const sidebarStatus = document.getElementById("sidebar-status");
  const sidebarDeleteButton = document.getElementById("sidebar-delete-btn");
  const sidebarLayoutForm = document.getElementById("sidebar-layout-form");

  let navItems = JSON.parse(JSON.stringify(initialNavbarLinks || []));
  let sidebarState = JSON.parse(JSON.stringify(initialSidebarLayout || {}));

  function resetNavForm() {
    navForm.reset();
    navForm.elements.index.value = "";
    navForm.elements.childrenJson.value = "";
    navDeleteButton.hidden = true;
  }

  function resetSidebarForm() {
    sidebarForm.reset();
    sidebarForm.elements.index.value = "";
    sidebarForm.elements.order.value = String((sidebarState.components?.length || 0) + 1);
    sidebarForm.elements.animationDelay.value = "0";
    sidebarForm.elements.enable.checked = true;
    sidebarDeleteButton.hidden = true;
  }

  function renderNavList() {
    navList.innerHTML = navItems
      .map((item, index) => `
        <div class="rounded-2xl border border-[var(--line-color)] p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="font-semibold">${item.name}</div>
              <div class="mt-1 text-sm text-50">${item.url}</div>
              ${item.children?.length ? `<div class="mt-1 text-xs text-50">${item.children.length} submenu</div>` : ""}
            </div>
            <div class="flex gap-2">
              <button class="btn-plain rounded-lg px-3 py-2 text-sm" type="button" data-nav-edit="${index}">Edit</button>
              <button class="btn-plain rounded-lg px-3 py-2 text-sm" type="button" data-nav-up="${index}">Naik</button>
              <button class="btn-plain rounded-lg px-3 py-2 text-sm" type="button" data-nav-down="${index}">Turun</button>
            </div>
          </div>
        </div>
      `)
      .join("");

    navList.querySelectorAll("[data-nav-edit]").forEach((button) => {
      button.addEventListener("click", () => {
        const index = Number(button.dataset.navEdit);
        const item = navItems[index];
        navForm.elements.index.value = String(index);
        navForm.elements.name.value = item.name || "";
        navForm.elements.url.value = item.url || "";
        navForm.elements.icon.value = item.icon || "";
        navForm.elements.external.checked = Boolean(item.external);
        navForm.elements.childrenJson.value = item.children?.length ? JSON.stringify(item.children, null, 2) : "";
        navDeleteButton.hidden = false;
      });
    });

    navList.querySelectorAll("[data-nav-up], [data-nav-down]").forEach((button) => {
      button.addEventListener("click", () => {
        const isUp = button.hasAttribute("data-nav-up");
        const index = Number(isUp ? button.dataset.navUp : button.dataset.navDown);
        const target = isUp ? index - 1 : index + 1;
        if (target < 0 || target >= navItems.length) return;
        [navItems[index], navItems[target]] = [navItems[target], navItems[index]];
        renderNavList();
        saveNavbar();
      });
    });
  }

  function renderSidebarList() {
    sidebarList.innerHTML = (sidebarState.components || [])
      .map((item, index) => `
        <div class="rounded-2xl border border-[var(--line-color)] p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="font-semibold">${item.type}</div>
              <div class="mt-1 text-sm text-50">order ${item.order} | ${item.position} | ${item.enable ? "aktif" : "nonaktif"}</div>
            </div>
            <button class="btn-plain rounded-lg px-3 py-2 text-sm" type="button" data-sidebar-edit="${index}">Edit</button>
          </div>
        </div>
      `)
      .join("");

    sidebarList.querySelectorAll("[data-sidebar-edit]").forEach((button) => {
      button.addEventListener("click", () => {
        const index = Number(button.dataset.sidebarEdit);
        const item = sidebarState.components[index];
        sidebarForm.elements.index.value = String(index);
        sidebarForm.elements.type.value = item.type || "profile";
        sidebarForm.elements.position.value = item.position || "top";
        sidebarForm.elements.order.value = String(item.order || 1);
        sidebarForm.elements.animationDelay.value = String(item.animationDelay || 0);
        sidebarForm.elements.className.value = item.class || "";
        sidebarForm.elements.configId.value = item.configId || "";
        sidebarForm.elements.enable.checked = Boolean(item.enable);
        sidebarDeleteButton.hidden = false;
      });
    });
  }

  async function saveNavbar() {
    navStatus.textContent = "Menyimpan navbar...";
    try {
      const response = await fetch("/api/studio/config/", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          section: "navbarLinks",
          value: navItems,
        }),
      });
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || "Gagal menyimpan navbar.");
      }
      navStatus.textContent = "Navbar tersimpan.";
    } catch (error) {
      navStatus.textContent = error.message;
    }
  }

  async function saveSidebar() {
    sidebarStatus.textContent = "Menyimpan sidebar...";
    try {
      const response = await fetch("/api/studio/config/", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          section: "sidebarLayout",
          value: sidebarState,
        }),
      });
      const result = await response.json();
      if (!response.ok) {
        throw new Error(result.error || "Gagal menyimpan sidebar.");
      }
      sidebarStatus.textContent = "Sidebar tersimpan.";
    } catch (error) {
      sidebarStatus.textContent = error.message;
    }
  }

  document.getElementById("nav-add-btn")?.addEventListener("click", resetNavForm);
  document.getElementById("nav-reset-btn")?.addEventListener("click", resetNavForm);
  document.getElementById("sidebar-add-btn")?.addEventListener("click", resetSidebarForm);
  document.getElementById("sidebar-reset-btn")?.addEventListener("click", resetSidebarForm);
  document.getElementById("sidebar-save-all-btn")?.addEventListener("click", saveSidebar);

  navDeleteButton?.addEventListener("click", () => {
    const index = Number(navForm.elements.index.value);
    if (Number.isNaN(index)) return;
    navItems.splice(index, 1);
    renderNavList();
    resetNavForm();
    saveNavbar();
  });

  sidebarDeleteButton?.addEventListener("click", () => {
    const index = Number(sidebarForm.elements.index.value);
    if (Number.isNaN(index)) return;
    sidebarState.components.splice(index, 1);
    renderSidebarList();
    resetSidebarForm();
    saveSidebar();
  });

  navForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    let children = [];
    const rawChildren = navForm.elements.childrenJson.value.trim();
    if (rawChildren) {
      try {
        const parsedChildren = JSON.parse(rawChildren);
        if (!Array.isArray(parsedChildren)) {
          throw new Error("Submenu harus berbentuk array JSON.");
        }
        children = parsedChildren;
      } catch (error) {
        navStatus.textContent = error instanceof Error ? error.message : "Format submenu tidak valid.";
        return;
      }
    }

    const payload = {
      name: navForm.elements.name.value.trim(),
      url: navForm.elements.url.value.trim(),
      icon: navForm.elements.icon.value.trim() || undefined,
      external: navForm.elements.external.checked,
      ...(children.length ? { children } : {}),
    };

    const index = navForm.elements.index.value;
    if (index === "") {
      navItems.push(payload);
    } else {
      navItems[Number(index)] = payload;
    }

    renderNavList();
    await saveNavbar();
    resetNavForm();
  });

  sidebarForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const payload = {
      type: sidebarForm.elements.type.value,
      enable: sidebarForm.elements.enable.checked,
      order: Number(sidebarForm.elements.order.value || 1),
      position: sidebarForm.elements.position.value,
      class: sidebarForm.elements.className.value.trim() || undefined,
      animationDelay: Number(sidebarForm.elements.animationDelay.value || 0),
      configId: sidebarForm.elements.configId.value.trim() || undefined,
    };

    const index = sidebarForm.elements.index.value;
    if (index === "") {
      sidebarState.components.push(payload);
    } else {
      sidebarState.components[Number(index)] = payload;
    }

    renderSidebarList();
    await saveSidebar();
    resetSidebarForm();
  });

  sidebarLayoutForm?.elements.enable.addEventListener("change", () => {
    sidebarState.enable = sidebarLayoutForm.elements.enable.checked;
  });
  sidebarLayoutForm?.elements.position.addEventListener("change", () => {
    sidebarState.position = sidebarLayoutForm.elements.position.value;
  });

  sidebarLayoutForm.elements.enable.checked = Boolean(sidebarState.enable);
  sidebarLayoutForm.elements.position.value = sidebarState.position || "left";
  renderNavList();
  renderSidebarList();
  resetNavForm();
  resetSidebarForm();
</script>

<style>
  .studio-input {
    border: 1px solid color-mix(in oklab, var(--primary) 16%, transparent);
    border-radius: 1rem;
    background: var(--card-bg);
    padding: 0.875rem 1rem;
  }

  .studio-input:focus {
    outline: none;
    border-color: color-mix(in oklab, var(--primary) 50%, transparent);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--primary) 14%, transparent);
  }
</style>

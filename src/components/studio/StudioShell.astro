---
import { Icon } from "astro-icon/components";
import Breadcrumb from "@components/misc/Breadcrumb.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const isReadOnlyStudio = !import.meta.env.DEV;

const navItems = [
  { href: "/studio/", label: "Overview", icon: "material-symbols:dashboard-outline" },
  { href: "/studio/posts/", label: "Posts", icon: "material-symbols:article-outline" },
  { href: "/studio/site/", label: "Site", icon: "material-symbols:settings-outline" },
  { href: "/studio/appearance/", label: "Appearance", icon: "material-symbols:palette-outline" },
  { href: "/studio/navigation/", label: "Navigation", icon: "material-symbols:menu" },
  { href: "/studio/integrations/", label: "Integrations", icon: "material-symbols:extension-outline" },
  { href: "/studio/pages/", label: "Pages", icon: "material-symbols:pages-outline" },
];

const pageName = navItems.find((item) => Astro.url.pathname === item.href)?.label ?? title;
const breadcrumbItems =
  pageName === "Overview"
    ? [{ label: "Studio" }]
    : [{ label: "Studio", href: "/studio/" }, { label: pageName }];
---

<MainGridLayout title={title} description={description ?? title}>
  <Breadcrumb items={breadcrumbItems} />

  <div class="grid gap-6 lg:grid-cols-[16rem_minmax(0,1fr)]">
    <aside class="card-base h-fit p-4 lg:sticky lg:top-24">
      <div class="mb-5 px-1">
        <div class="mb-1 flex items-center gap-2">
          <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-[var(--btn-plain-bg)] text-[var(--primary)]">
            <Icon name="material-symbols:edit-square-outline-rounded" class="text-lg" />
          </span>
          <h1 class="text-lg font-bold">Studio</h1>
        </div>
        <p class="text-50 text-xs">NgetehNology · Local development tools</p>
      </div>

      <nav class="flex flex-col gap-1">
        {
          navItems.map((item) => {
            const active = Astro.url.pathname === item.href;
            return (
              <a
                href={item.href}
                class:list={[
                  "flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition",
                  active ? "bg-[var(--primary)] text-white shadow-sm" : "btn-plain text-75 hover:text-90",
                ]}
              >
                <Icon name={item.icon} class="text-base" />
                <span>{item.label}</span>
              </a>
            );
          })
        }
      </nav>
    </aside>

    <section class="min-w-0 space-y-6" data-studio-content>
      <div class="mb-2">
        <h2 class="text-2xl font-bold">{title}</h2>
        {description && <p class="text-50 mt-1">{description}</p>}
      </div>

      {
        isReadOnlyStudio && (
          <div class="card-base border border-amber-400/30 bg-amber-50/80 p-4 text-sm text-amber-900 dark:bg-amber-950/30 dark:text-amber-200">
            Studio pada deploy publik bersifat read-only. Penyimpanan file hanya aktif saat development lokal
            menggunakan <code>pnpm dev</code>.
          </div>
        )
      }

      <slot />
    </section>
  </div>
</MainGridLayout>

{
  isReadOnlyStudio && (
    <script is:inline>
      const disableStudioEditing = () => {
        const root = document.querySelector("[data-studio-content]");
        if (!root) return;

        root
          .querySelectorAll(
            "form button, form input, form textarea, form select, button[id$='-add-btn'], button[id$='-delete-btn'], button[id$='-reset-btn'], button[id$='-save-all-btn'], button[id='post-new-btn'], button[id='taxonomy-save-btn']",
          )
          .forEach((element) => {
            if (!(element instanceof HTMLButtonElement || element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement || element instanceof HTMLSelectElement)) {
              return;
            }
            if (element instanceof HTMLInputElement && element.type === "hidden") {
              return;
            }
            element.disabled = true;
            element.setAttribute("aria-disabled", "true");
          });
      };

      disableStudioEditing();

      if (window?.swup?.hooks) {
        window.swup.hooks.on("page:view", disableStudioEditing);
      }
    </script>
  )
}

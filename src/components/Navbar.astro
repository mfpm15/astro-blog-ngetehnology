---
import { Icon } from "astro-icon/components";
import { siteConfig, navBarConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import LayoutSwitchButton from "./LayoutSwitchButton.svelte";
import MobileTOC from "./MobileTOC.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import DropdownMenu from "./widget/DropdownMenu.astro";
import NavMenuPanel from "./widget/NavMenuPanel.astro";
import LanguageSwitch from "./LanguageSwitch.astro";

const className = Astro.props.class;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";

let links: NavBarLink[] = navBarConfig.links.map(
  (item: NavBarLink | LinkPreset): NavBarLink => {
    if (typeof item === "number") {
      return LinkPresets[item];
    }
    return item;
  },
);
---

<div id="navbar" class="z-[120] w-full onload-animation" data-is-home={isHomePage}>
  <div class="absolute left-0 right-0 -top-8 h-8 transition"></div>
  <div
    class:list={[
      className,
      "!overflow-visible mx-auto flex h-[4.5rem] max-w-[var(--page-width)] items-center justify-between gap-4 px-4",
    ]}
  >
    <a href={url("/")} class="btn-plain scale-animation h-[3.25rem] rounded-xl px-5 font-bold active:scale-95">
      <div class="flex flex-row items-center text-md text-black dark:text-white">
        {
          siteConfig.logoIcon?.type === "icon" ? (
            <Icon
              name={siteConfig.logoIcon.value || "material-symbols:home-pin-outline"}
              class="mb-1 mr-2 text-[1.75rem]"
            />
          ) : siteConfig.logoIcon?.type === "image" ? (
            <img
              src={siteConfig.logoIcon.value}
              alt={siteConfig.logoIcon.alt || siteConfig.title}
              class="mr-3 h-9 w-9 rounded-full object-cover ring-1 ring-black/10 dark:ring-white/10"
              width="36"
              height="36"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          ) : (
            <Icon name="material-symbols:home-pin-outline" class="mb-1 mr-2 text-[1.75rem]" />
          )
        }
        <span class="tracking-[0.02em]">{siteConfig.title}</span>
      </div>
    </a>

    <div class="hidden items-center space-x-1 md:flex">
      {links.map((link) => <DropdownMenu link={link} />)}
    </div>

    <div class="flex items-center gap-1">
      <Search client:only="svelte" />
      <MobileTOC client:only="svelte" />
      {
        !siteConfig.themeColor.fixed && (
          <button
            aria-label="Display Settings"
            class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90"
            id="display-settings-switch"
          >
            <Icon name="material-symbols:palette-outline" class="text-[1.25rem]" />
          </button>
        )
      }
      <LanguageSwitch />
      <LayoutSwitchButton client:only="svelte" currentLayout={siteConfig.postListLayout.defaultMode} />
      <LightDarkSwitch client:only="svelte" />
      <button
        aria-label="Menu"
        name="Nav Menu"
        class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90 md:!hidden"
        id="nav-menu-switch"
      >
        <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]" />
      </button>
    </div>

    <NavMenuPanel links={links} />
    <DisplaySettings client:only="svelte" />
  </div>
</div>

<script>
  function bindNavbarPanels() {
    const panelBindings = [
      ["display-settings-switch", "display-setting"],
      ["nav-menu-switch", "nav-menu-panel"],
      ["language-menu-switch", "language-menu-panel"],
    ];

    panelBindings.forEach(([buttonId, panelId]) => {
      const button = document.getElementById(buttonId);
      const panel = document.getElementById(panelId);
      if (!button || !panel) return;

      button.onclick = () => {
        panel.classList.toggle("float-panel-closed");
      };
    });
  }

  bindNavbarPanels();

  if (window?.swup?.hooks) {
    window.swup.hooks.on("page:view", bindNavbarPanels);
  } else {
    document.addEventListener("swup:enable", () => {
      window.swup?.hooks?.on("page:view", bindNavbarPanels);
    });
  }
</script>

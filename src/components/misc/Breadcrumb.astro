---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-4 flex flex-wrap items-center gap-1.5 text-sm text-50">
  <a href="/" class="transition hover:text-[var(--primary)]">Home</a>
  {
    items.map((item) => (
      <span class="flex items-center gap-1.5">
        <span class="opacity-40">/</span>
        {
          item.href ? (
            <a href={item.href} class="transition hover:text-[var(--primary)]">
              {item.label}
            </a>
          ) : (
            <span class="text-75">{item.label}</span>
          )
        }
      </span>
    ))
  }
</nav>

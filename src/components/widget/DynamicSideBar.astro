---
import type { MarkdownHeading } from "astro";
import type { WidgetComponentConfig } from "../../types/config";
import { widgetManager } from "../../utils/widget-manager";
import Announcement from "./Announcement.astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tags from "./Tags.astro";
import TOC from "./TOC.astro";
import Advertisement from "./Advertisement.astro";
import Calendar from "./Calendar.astro";
import MusicPlayer from "./MusicPlayer.svelte";
import SiteStats from "./SiteStats.astro";

interface Props {
  class?: string;
  headings?: MarkdownHeading[];
  side?: "left" | "right";
  isPostPage?: boolean;
  customComponents?: Record<string, any>;
}

const { class: className, headings, side = "left", isPostPage = false, customComponents = {} } = Astro.props;

const topComponents = widgetManager.getComponentsByPosition("top", side, isPostPage);
const stickyComponents = widgetManager.getComponentsByPosition("sticky", side, isPostPage);

const componentMap = {
  profile: Profile,
  announcement: Announcement,
  categories: Categories,
  tags: Tags,
  toc: TOC,
  sidebarToc: TOC,
  advertisement: Advertisement,
  calendar: Calendar,
  stats: SiteStats,
  "site-stats": SiteStats,
  music: MusicPlayer,
  "music-player": MusicPlayer,
  ...customComponents,
};

type RenderData = {
  Component: any;
  props: Record<string, unknown>;
  config: WidgetComponentConfig;
};

function createComponentRenderer(component: WidgetComponentConfig, index: number): RenderData | null {
  const ComponentToRender = componentMap[component.type as keyof typeof componentMap];
  if (!ComponentToRender) return null;

  const props: Record<string, unknown> = {
    class: widgetManager.getComponentClass(component, index),
    style: widgetManager.getComponentStyle(component, index),
    componentConfig: component,
    configId: component.configId,
    ...component.customProps,
  };

  if ((component.type === "toc" || component.type === "sidebarToc") && headings) {
    props.headings = headings;
  }

  return {
    Component: ComponentToRender as any,
    props,
    config: component,
  };
}

function renderComponents(components: WidgetComponentConfig[]) {
  return components
    .map((component, index) => createComponentRenderer(component, index))
    .filter(Boolean) as RenderData[];
}

const topComponentsToRender = renderComponents(topComponents);
const stickyComponentsToRender = renderComponents(stickyComponents);
const hasAnyComponents = topComponentsToRender.length > 0 || stickyComponentsToRender.length > 0;

const sidebarConfig = {
  breakpoints: widgetManager.getBreakpoints(),
  shouldShowSidebar: {
    mobile: widgetManager.shouldShowSidebarSide("mobile", side, isPostPage),
    tablet: widgetManager.shouldShowSidebarSide("tablet", side, isPostPage),
    desktop: widgetManager.shouldShowSidebarSide("desktop", side, isPostPage),
  },
  side,
};
---

{hasAnyComponents && (
  <div id={`dynamic-sidebar-${side}`} class:list={[className, "w-full"]} data-widget-manager="true">
    {topComponentsToRender.length > 0 && (
      <div class="sidebar-top-section flex w-full flex-col gap-4 mb-4" data-position="top">
        {topComponentsToRender.map(({ Component, props, config }) => (
          <div class="widget-container" data-widget-type={config.type} data-widget-order={config.order} data-widget-position={config.position}>
            <Component {...props} />
          </div>
        ))}
      </div>
    )}

    {stickyComponentsToRender.length > 0 && (
      <div
        id={`dynamic-sidebar-sticky-${side}`}
        class="sidebar-sticky-section sticky top-4 flex w-full flex-col gap-4 transition-all duration-700"
        data-position="sticky"
      >
        {stickyComponentsToRender.map(({ Component, props, config }) => (
          <div class="widget-container" data-widget-type={config.type} data-widget-order={config.order} data-widget-position={config.position}>
            <Component {...props} />
          </div>
        ))}
      </div>
    )}
  </div>
)}

{!hasAnyComponents && (
  <div class="sidebar-placeholder p-4 text-center text-gray-500 dark:text-gray-400">
    <p>No widgets enabled</p>
    <p class="text-sm">Configure widgets in your config file</p>
  </div>
)}

<style>
  .widget-container {
    transition: all 0.3s ease;
  }

  .sidebar-placeholder {
    border: 2px dashed currentColor;
    border-radius: 0.5rem;
    opacity: 0.5;
  }
</style>

<script define:vars={{ sidebarConfig }}>
  class DynamicSidebarManager {
    constructor() {
      this.config = sidebarConfig;
      this.init();
    }

    init() {
      this.updateResponsiveDisplay();
      window.addEventListener("resize", () => this.updateResponsiveDisplay());
    }

    updateResponsiveDisplay() {
      const breakpoints = this.config.breakpoints;
      const width = window.innerWidth;

      let deviceType;
      if (width < breakpoints.mobile) {
        deviceType = "mobile";
      } else if (width < breakpoints.desktop) {
        deviceType = "tablet";
      } else {
        deviceType = "desktop";
      }

      const sidebar = document.getElementById(`dynamic-sidebar-${this.config.side}`);
      if (!sidebar) return;

      sidebar.style.display = this.config.shouldShowSidebar[deviceType] ? "block" : "none";
      sidebar.setAttribute("data-device-type", deviceType);
    }
  }

  new DynamicSidebarManager();
</script>

---
import { Icon } from "astro-icon/components";
import { url } from "../../utils/url-utils";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
  class?: string;
  style?: string;
}

const { class: className, style } = Astro.props;
const locale = "en-US";
const monthNames = Array.from({ length: 12 }, (_, index) =>
  new Date(2026, index, 1).toLocaleString(locale, { month: "short" }),
);
const weekDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const labels = {
  title: "Calendar",
  today: "Today",
  noDailyPosts: "No posts on this day.",
  loading: "Loading post calendar...",
  more: "More",
};

const calendarDataUrl = url("/api/allPostMeta.json");
const postUrlPrefix = url("/posts/");
---

<WidgetLayout name={labels.title} id="calendar-widget" class={className} style={style}>
  <div
    class="calendar-widget"
    data-calendar-root
    data-calendar-locale={locale}
    data-calendar-url={calendarDataUrl}
    data-calendar-post-prefix={postUrlPrefix}
    data-label-today={labels.today}
    data-label-no-daily-posts={labels.noDailyPosts}
    data-label-loading={labels.loading}
    data-label-more={labels.more}
  >
    <div class="mb-3 flex items-center justify-between gap-2">
      <button
        type="button"
        class="btn-plain flex h-9 w-9 shrink-0 items-center justify-center rounded-lg"
        data-calendar-prev
        aria-label="Previous"
      >
        <Icon name="fa6-solid:chevron-left" class="text-sm" />
      </button>

      <button
        type="button"
        class="min-w-0 flex-1 rounded-lg px-2 py-1 text-center text-sm font-semibold text-neutral-800 transition hover:bg-[var(--btn-plain-bg-hover)] dark:text-neutral-100"
        data-calendar-label
        aria-label="Switch calendar view"
      ></button>

      <div class="flex items-center gap-1">
        <button
          type="button"
          class="btn-plain flex h-9 w-9 shrink-0 items-center justify-center rounded-lg"
          data-calendar-reset
          aria-label="Reset"
        >
          <Icon name="fa6-solid:arrow-rotate-left" class="text-sm" />
        </button>
        <button
          type="button"
          class="btn-plain flex h-9 w-9 shrink-0 items-center justify-center rounded-lg"
          data-calendar-next
          aria-label="Next"
        >
          <Icon name="fa6-solid:chevron-right" class="text-sm" />
        </button>
      </div>
    </div>

    <div data-calendar-day-view>
      <div class="mb-2 grid grid-cols-7 gap-1 text-[11px] font-medium uppercase tracking-wide text-neutral-400 dark:text-neutral-500">
        {
          weekDays.map((label) => (
            <div class="py-1 text-center">{label}</div>
          ))
        }
      </div>

      <div class="grid grid-cols-7 gap-1 pb-1" data-calendar-grid></div>
    </div>

    <div class="hidden grid-cols-3 gap-2" data-calendar-month-view></div>
    <div class="hidden grid-cols-3 gap-2" data-calendar-year-view></div>

    <div class="mt-3" data-calendar-posts>
      <div class="mb-2 border-t border-[var(--line-color)]" data-calendar-divider></div>
      <div class="flex max-h-44 flex-col gap-1 overflow-y-auto pr-1" data-calendar-post-list>
        <div class="rounded-xl bg-[var(--btn-plain-bg)] px-3 py-2 text-sm text-neutral-500 dark:text-neutral-400">
          {labels.loading}
        </div>
      </div>
    </div>
  </div>
</WidgetLayout>

<script
  is:inline
  data-swup-ignore-script
  define:vars={{ monthNames, weekDays }}
>
  function initAdvancedCalendars(options) {
    const opts = options || {};
    const force = opts.force === true;
    const roots = document.querySelectorAll("[data-calendar-root]");

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement)) return;

      const existing = root.__ngetehCalendarController;
      if (existing && typeof existing.destroy === "function") {
        if (!force) return;
        existing.destroy();
      }

      const controller = createCalendarController(root);
      if (!controller) return;
      root.__ngetehCalendarController = controller;
      controller.init();
    });
  }

  function createCalendarController(root) {
    const locale = root.dataset.calendarLocale || "en-US";
    const calendarDataUrl = root.dataset.calendarUrl || "/api/allPostMeta.json";
    const postUrlPrefix = root.dataset.calendarPostPrefix || "/posts/";
    const labelToday = root.dataset.labelToday || "Today";
    const noDailyPosts = root.dataset.labelNoDailyPosts || "No posts on this day.";
    const labelLoading = root.dataset.labelLoading || "Loading post calendar...";
    const labelMore = root.dataset.labelMore || "More";

    const dayView = root.querySelector("[data-calendar-day-view]");
    const monthView = root.querySelector("[data-calendar-month-view]");
    const yearView = root.querySelector("[data-calendar-year-view]");
    const grid = root.querySelector("[data-calendar-grid]");
    const label = root.querySelector("[data-calendar-label]");
    const prevBtn = root.querySelector("[data-calendar-prev]");
    const nextBtn = root.querySelector("[data-calendar-next]");
    const resetBtn = root.querySelector("[data-calendar-reset]");
    const postsWrapper = root.querySelector("[data-calendar-posts]");
    const divider = root.querySelector("[data-calendar-divider]");
    const postsList = root.querySelector("[data-calendar-post-list]");

    if (
      !dayView ||
      !monthView ||
      !yearView ||
      !grid ||
      !label ||
      !prevBtn ||
      !nextBtn ||
      !resetBtn ||
      !postsWrapper ||
      !divider ||
      !postsList
    ) {
      return null;
    }

    const today = new Date();
    let displayYear = today.getFullYear();
    let displayMonth = today.getMonth();
    let selectedDay = today.getDate();
    let selectedDateKey = formatDateKey(displayYear, displayMonth, selectedDay);
    let currentView = "day";

    let allPostsData = [];
    let postDateMap = {};
    let availableYears = [];
    let dataStatus = "loading";

    function formatDateKey(year, month, day) {
      return `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
    }

    function parseDateKey(dateKey) {
      const parts = dateKey.split("-");
      if (parts.length !== 3) return null;
      const year = Number.parseInt(parts[0], 10);
      const month = Number.parseInt(parts[1], 10) - 1;
      const day = Number.parseInt(parts[2], 10);
      if (!Number.isFinite(year) || !Number.isFinite(month) || !Number.isFinite(day)) return null;
      return { year, month, day };
    }

    function clampDay(year, month, day) {
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      return Math.min(Math.max(day, 1), daysInMonth);
    }

    function setSelectedDate(year, month, day) {
      selectedDay = clampDay(year, month, day);
      displayYear = year;
      displayMonth = month;
      selectedDateKey = formatDateKey(displayYear, displayMonth, selectedDay);
    }

    function isAtToday() {
      return (
        displayYear === today.getFullYear() &&
        displayMonth === today.getMonth() &&
        selectedDay === today.getDate()
      );
    }

    function shiftMonth(delta) {
      let nextYear = displayYear;
      let nextMonth = displayMonth + delta;

      while (nextMonth < 0) {
        nextMonth += 12;
        nextYear -= 1;
      }
      while (nextMonth > 11) {
        nextMonth -= 12;
        nextYear += 1;
      }

      setSelectedDate(nextYear, nextMonth, selectedDay);
    }

    function renderPostList(posts) {
      if (dataStatus === "loading") {
        postsWrapper.style.display = "block";
        divider.style.display = "none";
        postsList.innerHTML = `<div class="rounded-xl bg-[var(--btn-plain-bg)] px-3 py-2 text-sm text-neutral-500 dark:text-neutral-400">${labelLoading}</div>`;
        return;
      }

      if (!Array.isArray(posts) || posts.length === 0) {
        postsWrapper.style.display = "block";
        divider.style.display = "none";
        postsList.innerHTML = `<div class="rounded-xl bg-[var(--btn-plain-bg)] px-3 py-2 text-sm text-neutral-500 dark:text-neutral-400">${noDailyPosts}</div>`;
        return;
      }

      postsWrapper.style.display = "block";
      divider.style.display = "block";

      const visiblePosts = posts.slice(0, 2);
      const morePosts = posts.slice(2);

      const renderPostItem = (post) => {
        const date = new Date(post.published);
        const dateText = date.toLocaleDateString(locale, { day: "2-digit", month: "short" });
        return `
          <a
            href="${postUrlPrefix}${post.slug}/"
            class="flex items-center justify-between gap-3 rounded-xl px-3 py-2 text-sm text-neutral-700 transition hover:bg-[var(--btn-plain-bg-hover)] dark:text-neutral-200"
          >
            <span class="truncate font-medium">${post.title}</span>
            <span class="shrink-0 text-[11px] text-neutral-500 dark:text-neutral-400">${dateText}</span>
          </a>
        `;
      };

      const visibleHtml = visiblePosts.map(renderPostItem).join("");
      if (morePosts.length === 0) {
        postsList.innerHTML = visibleHtml;
        return;
      }

      const moreHtml = morePosts.map(renderPostItem).join("");
      postsList.innerHTML = `
        ${visibleHtml}
        <button
          type="button"
          class="btn-plain scale-animation rounded-lg w-full h-9 flex items-center justify-center gap-2 active:scale-95 mt-1"
          data-calendar-more
        >
          ${labelMore}
          <span class="text-xs opacity-60">(${morePosts.length})</span>
        </button>
        <div class="mt-1 hidden flex flex-col gap-1" data-calendar-more-panel>
          ${moreHtml}
        </div>
      `;
    }

    function updateHeader() {
      const monthLabel = new Date(displayYear, displayMonth, 1).toLocaleDateString(locale, {
        month: "long",
        year: "numeric",
      });

      if (currentView === "day") {
        label.textContent = monthLabel;
      } else if (currentView === "month") {
        label.textContent = String(displayYear);
      } else {
        label.textContent = labelToday;
      }

      resetBtn.style.visibility = currentView === "day" && isAtToday() ? "hidden" : "visible";
      prevBtn.style.visibility = currentView === "year" ? "hidden" : "visible";
      nextBtn.style.visibility = currentView === "year" ? "hidden" : "visible";
    }

    function renderDayView() {
      const firstDayOfMonth = new Date(displayYear, displayMonth, 1).getDay();
      const daysInMonth = new Date(displayYear, displayMonth + 1, 0).getDate();
      const isCurrentMonth = displayYear === today.getFullYear() && displayMonth === today.getMonth();

      const cells = [];
      for (let index = 0; index < firstDayOfMonth; index += 1) {
        cells.push('<div aria-hidden="true" class="aspect-square min-h-[2rem] rounded-xl sm:min-h-[2.2rem]"></div>');
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const dateKey = formatDateKey(displayYear, displayMonth, day);
        const posts = postDateMap[dateKey] || [];
        const isToday = isCurrentMonth && day === today.getDate();
        const isSelected = selectedDateKey === dateKey;

        const classNames = [
          "calendar-day",
          "relative",
          "flex",
          "aspect-square",
          "min-h-[2rem]",
          "items-center",
          "justify-center",
          "rounded-xl",
          "text-xs",
          "font-medium",
          "transition",
          "sm:min-h-[2.2rem]",
          "cursor-pointer",
          posts.length > 0 ? "text-neutral-900 dark:text-neutral-100" : "text-neutral-600 dark:text-neutral-400",
          isSelected ? "bg-[var(--btn-plain-bg-hover)]" : "bg-[var(--btn-plain-bg)]",
        ];

        if (isToday) {
          classNames.push("ring-2", "ring-[var(--primary)]");
        }

        cells.push(`
          <button type="button" class="${classNames.join(" ")}" data-date="${dateKey}">
            <span>${day}</span>
            ${posts.length > 0 ? '<span class="absolute bottom-1 left-1/2 h-1.5 w-1.5 -translate-x-1/2 rounded-full bg-[var(--primary)]"></span>' : ""}
            ${posts.length > 1 ? `<span class="absolute right-0.5 top-0.5 rounded-full bg-[var(--primary)]/14 px-1 text-[10px] font-bold text-[var(--primary)]">${posts.length}</span>` : ""}
          </button>
        `);
      }

      grid.innerHTML = cells.join("");
      renderPostList(postDateMap[selectedDateKey] || []);
    }

    function renderMonthView() {
      const monthsWithPosts = new Set();
      if (Array.isArray(allPostsData) && allPostsData.length) {
        allPostsData.forEach((post) => {
          const date = new Date(post.published);
          if (date.getFullYear() === displayYear) {
            monthsWithPosts.add(date.getMonth());
          }
        });
      }

      monthView.innerHTML = monthNames
        .map((monthName, index) => {
          const active = index === displayMonth;
          const hasPosts = monthsWithPosts.has(index);
          return `
            <button
              type="button"
              class="relative rounded-xl px-2 py-3 text-sm transition ${
                active
                  ? "bg-[var(--btn-plain-bg-hover)] font-bold text-[var(--primary)]"
                  : "bg-[var(--btn-plain-bg)] text-neutral-700 hover:bg-[var(--btn-plain-bg-hover)] dark:text-neutral-200"
              }"
              data-month="${index}"
            >
              ${monthName}
              ${hasPosts ? '<span class="absolute bottom-1 left-1/2 h-1.5 w-1.5 -translate-x-1/2 rounded-full bg-[var(--primary)]"></span>' : ""}
            </button>
          `;
        })
        .join("");
    }

    function renderYearView() {
      const yearItems = availableYears.length
        ? availableYears
        : Array.from({ length: 9 }, (_, index) => today.getFullYear() - index);

      yearView.innerHTML = yearItems
        .map((year) => {
          const active = year === displayYear;
          return `
            <button
              type="button"
              class="rounded-xl px-2 py-3 text-sm transition ${
                active
                  ? "bg-[var(--btn-plain-bg-hover)] font-bold text-[var(--primary)]"
                  : "bg-[var(--btn-plain-bg)] text-neutral-700 hover:bg-[var(--btn-plain-bg-hover)] dark:text-neutral-200"
              }"
              data-year="${year}"
            >
              ${year}
            </button>
          `;
        })
        .join("");
    }

    function renderCalendar() {
      dayView.classList.toggle("hidden", currentView !== "day");
      monthView.classList.toggle("hidden", currentView !== "month");
      monthView.classList.toggle("grid", currentView === "month");
      yearView.classList.toggle("hidden", currentView !== "year");
      yearView.classList.toggle("grid", currentView === "year");
      postsWrapper.classList.toggle("hidden", currentView !== "day");

      updateHeader();

      if (currentView === "day") {
        renderDayView();
      } else if (currentView === "month") {
        renderMonthView();
      } else {
        renderYearView();
      }
    }

    async function fetchCalendarData() {
      try {
        dataStatus = "loading";
        renderCalendar();

        if (window.__allPostMetaCache) {
          allPostsData = window.__allPostMetaCache;
        } else {
          const response = await fetch(calendarDataUrl);
          allPostsData = await response.json();
          window.__allPostMetaCache = allPostsData;
        }

        postDateMap = {};
        const years = new Set();

        allPostsData.forEach((post) => {
          const date = new Date(post.published);
          const dateKey = formatDateKey(date.getFullYear(), date.getMonth(), date.getDate());
          if (!postDateMap[dateKey]) {
            postDateMap[dateKey] = [];
          }
          postDateMap[dateKey].push(post);
          years.add(date.getFullYear());
        });

        Object.keys(postDateMap).forEach((key) => {
          postDateMap[key].sort((a, b) => new Date(b.published).getTime() - new Date(a.published).getTime());
        });

        availableYears = Array.from(years).sort((left, right) => right - left);
        dataStatus = "loaded";
      } catch (error) {
        console.error("Failed to load calendar metadata", error);
        allPostsData = [];
        postDateMap = {};
        availableYears = [];
        dataStatus = "error";
      } finally {
        renderCalendar();
      }
    }

    function onPrevClick() {
      if (currentView === "day") {
        shiftMonth(-1);
      } else if (currentView === "month") {
        setSelectedDate(displayYear - 1, displayMonth, selectedDay);
      }
      renderCalendar();
    }

    function onNextClick() {
      if (currentView === "day") {
        shiftMonth(1);
      } else if (currentView === "month") {
        setSelectedDate(displayYear + 1, displayMonth, selectedDay);
      }
      renderCalendar();
    }

    function onResetClick() {
      setSelectedDate(today.getFullYear(), today.getMonth(), today.getDate());
      currentView = "day";
      renderCalendar();
    }

    function onLabelClick() {
      if (currentView === "day") {
        currentView = "month";
      } else if (currentView === "month") {
        currentView = "year";
      } else {
        currentView = "day";
      }
      renderCalendar();
    }

    function onGridClick(event) {
      const target = event.target;
      const button = target && target.closest ? target.closest("[data-date]") : null;
      if (!button) return;
      const dateKey = button.getAttribute("data-date") || "";
      const parsed = parseDateKey(dateKey);
      if (!parsed) return;
      setSelectedDate(parsed.year, parsed.month, parsed.day);
      renderCalendar();
    }

    function onMonthClick(event) {
      const target = event.target;
      const button = target && target.closest ? target.closest("[data-month]") : null;
      if (!button) return;
      const month = Number.parseInt(button.getAttribute("data-month") || "0", 10);
      if (!Number.isFinite(month)) return;
      setSelectedDate(displayYear, month, selectedDay);
      currentView = "day";
      renderCalendar();
    }

    function onYearClick(event) {
      const target = event.target;
      const button = target && target.closest ? target.closest("[data-year]") : null;
      if (!button) return;
      const year = Number.parseInt(button.getAttribute("data-year") || `${today.getFullYear()}`, 10);
      if (!Number.isFinite(year)) return;
      setSelectedDate(year, displayMonth, selectedDay);
      currentView = "month";
      renderCalendar();
    }

    function onPostsListClick(event) {
      const target = event.target;
      const button = target && target.closest ? target.closest("[data-calendar-more]") : null;
      if (!button) return;
      const panel = postsList.querySelector("[data-calendar-more-panel]");
      if (panel) {
        panel.classList.remove("hidden");
      }
      button.remove();
    }

    function destroy() {
      prevBtn.removeEventListener("click", onPrevClick);
      nextBtn.removeEventListener("click", onNextClick);
      resetBtn.removeEventListener("click", onResetClick);
      label.removeEventListener("click", onLabelClick);
      grid.removeEventListener("click", onGridClick);
      monthView.removeEventListener("click", onMonthClick);
      yearView.removeEventListener("click", onYearClick);
      postsList.removeEventListener("click", onPostsListClick);
    }

    function init() {
      prevBtn.addEventListener("click", onPrevClick);
      nextBtn.addEventListener("click", onNextClick);
      resetBtn.addEventListener("click", onResetClick);
      label.addEventListener("click", onLabelClick);
      grid.addEventListener("click", onGridClick);
      monthView.addEventListener("click", onMonthClick);
      yearView.addEventListener("click", onYearClick);
      postsList.addEventListener("click", onPostsListClick);

      renderCalendar();
      fetchCalendarData();
    }

    return { init, destroy };
  }

  window.__ngetehInitCalendar = initAdvancedCalendars;
  initAdvancedCalendars();
</script>

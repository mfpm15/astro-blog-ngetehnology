---
import { Icon } from "astro-icon/components";
import type { MarkdownHeading } from "astro";
import { siteConfig } from "../../config/siteConfig";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
  headings: MarkdownHeading[];
}

const { headings = [] } = Astro.props;
const maxLevel = siteConfig.toc.depth;
const minDepth = headings.reduce((min, heading) => Math.min(min, heading.depth), 10);

let rootHeadingCount = 1;
const tocHeadings = headings
  .filter((heading) => heading.depth < minDepth + maxLevel)
  .map((heading) => {
    const levelOffset = Math.min(Math.max(heading.depth - minDepth, 0), 2);
    const rootNumber = levelOffset === 0 ? rootHeadingCount++ : null;
    return {
      id: heading.slug,
      text: heading.text,
      levelOffset,
      rootNumber,
    };
  });
---

{
  tocHeadings.length > 0 && (
    <div class="floating-toc-mount" style="display: contents">
      <div class="floating-toc-wrapper hidden lg:block">
        <button
          id="floating-toc-btn"
          type="button"
          class="floating-toc-btn hide flex items-center rounded-2xl overflow-hidden transition"
          aria-label="Open table of contents"
        >
          <span class="flex h-[3.75rem] w-[3.75rem] items-center justify-center rounded-2xl">
            <Icon name="material-symbols:format-list-bulleted" class="mx-auto" />
          </span>
        </button>
      </div>

      <div
        id="floating-toc-panel"
        class="floating-toc-panel hide fixed w-80 max-h-[24rem] overflow-hidden rounded-2xl shadow-2xl backdrop-blur-lg border border-white/20 bg-white/60 dark:bg-black/60 dark:border-white/10 z-50"
        style="background-color: rgba(var(--card-bg-rgb, 255, 255, 255), 0.6); bottom: calc(13rem + 6rem); right: 2rem;"
        aria-label="Table of contents panel"
      >
        <div
          class="p-4 border-b border-gray-200 dark:border-gray-700 sticky top-0 backdrop-blur-sm z-10"
          style="background-color: rgba(var(--card-bg-rgb, 255, 255, 255), 0.6);"
        >
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-[var(--primary)] flex items-center gap-2">
              {i18n(I18nKey.tableOfContents)}
            </h3>
            <button
              id="floating-toc-close"
              type="button"
              aria-label="Close table of contents"
              class="btn-plain rounded-lg h-8 w-8 active:scale-90"
            >
              <Icon name="material-symbols:close" class="text-lg" />
            </button>
          </div>
        </div>

        <div class="p-4" data-floating-toc-scroll style="overflow-y: auto; max-height: calc(24rem - 5rem);">
          <div class="toc-content" id="floating-toc-content" style="width: 100%; max-width: 100%;">
            {
              tocHeadings.map((heading) => (
                <a
                  href={`#${heading.id}`}
                  class={`toc-entry toc-depth-${heading.levelOffset}`}
                  data-heading-id={heading.id}
                  aria-label={`Go to ${heading.text}`}
                >
                  <span class={`toc-marker-slot toc-shift-${heading.levelOffset}`}>
                    {heading.levelOffset === 0 ? (
                      <span class="toc-marker toc-marker-root">{heading.rootNumber}</span>
                    ) : heading.levelOffset === 1 ? (
                      <span class="toc-marker toc-marker-mid"></span>
                    ) : (
                      <span class="toc-marker toc-marker-leaf"></span>
                    )}
                  </span>
                  <span
                    class={`toc-entry-text ${
                      heading.levelOffset === 0
                        ? "toc-entry-text-root"
                        : heading.levelOffset === 1
                          ? "toc-entry-text-mid"
                          : "toc-entry-text-leaf"
                    }`}
                  >
                    {heading.text}
                  </span>
                </a>
              ))
            }

            <div id="floating-active-indicator" style="opacity: 0" class="floating-active-indicator"></div>
          </div>
        </div>
      </div>
    </div>
  )
}

<style>
  .floating-toc-wrapper {
    width: 3.75rem;
    height: 3.75rem;
    position: absolute;
    right: 0;
    top: 0;
    pointer-events: none;
  }

  .floating-toc-btn {
    color: var(--primary);
    font-size: 2.25rem;
    font-weight: bold;
    border: none;
    position: fixed;
    bottom: 13rem;
    right: 2rem;
    opacity: 1;
    cursor: pointer;
    pointer-events: auto;
    z-index: 1000;
    transition: all 0.3s ease;
    border-radius: 1rem;
    backdrop-filter: blur(12px);
    background-color: var(--card-bg);
    border: 1px solid rgb(0 0 0 / 0.1);
  }

  .floating-toc-btn.hide {
    transform: scale(0.9);
    opacity: 0;
    pointer-events: none;
  }

  .floating-toc-btn:active {
    transform: scale(0.9);
  }

  .floating-toc-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.15);
    background-color: rgb(255 255 255 / 0.95);
    border-color: rgb(0 0 0 / 0.2);
  }

  :global(.dark) .floating-toc-btn {
    background-color: var(--card-bg);
    border: 1px solid rgb(255 255 255 / 0.15);
    color: var(--primary, #60a5fa);
  }

  :global(.dark) .floating-toc-btn:hover {
    background-color: var(--card-bg);
    border-color: rgb(255 255 255 / 0.3);
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.3);
  }

  .floating-toc-panel {
    transition: all 0.3s ease;
    transform: translateY(20px);
    opacity: 0;
    pointer-events: none;
    overflow: hidden;
    box-sizing: border-box;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .floating-toc-panel.show {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .floating-toc-panel.hide {
    transform: translateY(20px);
    opacity: 0;
    pointer-events: none;
  }

  .toc-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    contain: layout;
    align-items: flex-start;
  }

  .toc-entry {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
    position: relative;
    padding: 0.55rem 0.65rem;
    gap: 0.55rem;
  }

  .toc-entry:hover {
    background: var(--toc-btn-hover);
  }

  .toc-entry.visible {
    background: var(--toc-btn-active);
    color: var(--primary);
  }

  .toc-marker-slot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    flex-shrink: 0;
  }

  .toc-shift-1 {
    margin-left: 0.85rem;
  }

  .toc-shift-2 {
    margin-left: 1.7rem;
  }

  .toc-marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition: all 0.18s ease;
  }

  .toc-marker-root {
    height: 1.5rem;
    width: 1.5rem;
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--primary) 16%, transparent);
    color: var(--primary);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .toc-marker-mid {
    height: 0.48rem;
    width: 0.48rem;
    background: color-mix(in srgb, var(--primary) 76%, transparent);
  }

  .toc-marker-leaf {
    height: 0.36rem;
    width: 0.36rem;
    background: color-mix(in srgb, currentColor 30%, transparent);
    opacity: 0.75;
  }

  .toc-entry-text {
    min-width: 0;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.35;
  }

  .toc-entry-text-root {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .toc-entry-text-mid {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .toc-entry-text-leaf {
    font-size: 0.8rem;
  }

  .floating-active-indicator {
    position: absolute;
    left: 0;
    right: 0;
    z-index: -1;
    border: 1px dashed color-mix(in srgb, var(--primary) 24%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--primary) 9%, transparent);
    transition: top 180ms ease, height 180ms ease, opacity 180ms ease;
    pointer-events: none;
  }
</style>

<script is:inline data-swup-ignore-script>
  (function bootstrapFloatingTOC() {
    if (typeof window === "undefined") return;

    const MIN_WIDTH_PX = 1024;

    function getNavbarHeight() {
      const navbar =
        document.getElementById("navbar") ||
        document.getElementById("navbar-wrapper") ||
        document.querySelector("nav");
      if (navbar instanceof HTMLElement) {
        const rect = navbar.getBoundingClientRect();
        if (rect.height > 0) return rect.height;
      }
      return 80;
    }

    function getReadingLineOffset() {
      return Math.round(getNavbarHeight() + 16);
    }

    function closePanel(panel) {
      panel.classList.add("hide");
      panel.classList.remove("show");
    }

    function openPanel(panel) {
      panel.classList.remove("hide");
      panel.classList.add("show");
    }

    function isPanelOpen(panel) {
      return panel.classList.contains("show") && !panel.classList.contains("hide");
    }

    function init() {
      if (typeof window.__floatingTocCleanup === "function") {
        window.__floatingTocCleanup();
        window.__floatingTocCleanup = null;
      }

      if (!window.matchMedia(`(min-width: ${MIN_WIDTH_PX}px)`).matches) return;

      const btn = document.getElementById("floating-toc-btn");
      const panel = document.getElementById("floating-toc-panel");
      const closeBtn = document.getElementById("floating-toc-close");
      const content = document.getElementById("floating-toc-content");
      const indicator = document.getElementById("floating-active-indicator");
      const scrollContainer = panel?.querySelector?.("[data-floating-toc-scroll]");

      if (
        !(btn instanceof HTMLElement) ||
        !(panel instanceof HTMLElement) ||
        !(closeBtn instanceof HTMLElement) ||
        !(content instanceof HTMLElement) ||
        !(indicator instanceof HTMLElement) ||
        !(scrollContainer instanceof HTMLElement)
      ) {
        return;
      }

      const links = Array.from(content.querySelectorAll("a[href^='#']"));
      if (links.length === 0) {
        btn.classList.add("hide");
        closePanel(panel);
        return;
      }

      btn.classList.remove("hide");

      const pairs = links
        .map((link) => {
          const id = decodeURIComponent(link.hash?.substring(1) || "");
          const heading = document.getElementById(id);
          if (!(heading instanceof HTMLElement)) return null;
          return { id, link, heading };
        })
        .filter(Boolean);

      if (pairs.length === 0) {
        btn.classList.add("hide");
        closePanel(panel);
        return;
      }

      let activeIndex = -1;
      let scheduled = false;
      let anchorNavTarget = null;

      function resolveActiveIndex() {
        const readLine = getReadingLineOffset();
        let active = 0;
        for (let i = 0; i < pairs.length; i += 1) {
          const rect = pairs[i].heading.getBoundingClientRect();
          if (rect.top <= readLine) {
            active = i;
          } else {
            break;
          }
        }
        return active;
      }

      function updateIndicator() {
        if (activeIndex < 0 || activeIndex >= pairs.length) {
          indicator.style.opacity = "0";
          return;
        }

        const entry = pairs[activeIndex].link;
        indicator.style.top = `${entry.offsetTop}px`;
        indicator.style.height = `${entry.offsetHeight}px`;
        indicator.style.opacity = "1";
      }

      function scrollToActiveEntry() {
        if (!isPanelOpen(panel)) return;
        if (activeIndex < 0 || activeIndex >= pairs.length) return;

        const entry = pairs[activeIndex].link;
        const tocHeight = scrollContainer.clientHeight;
        const margin = 24;

        const entryTop = entry.offsetTop;
        const entryBottom = entryTop + entry.offsetHeight;
        const viewTop = scrollContainer.scrollTop;
        const viewBottom = viewTop + tocHeight;

        if (entryTop < viewTop + margin) {
          scrollContainer.scrollTo({
            top: Math.max(0, entryTop - margin),
            left: 0,
            behavior: "smooth",
          });
        } else if (entryBottom > viewBottom - margin) {
          scrollContainer.scrollTo({
            top: Math.max(0, entryBottom - tocHeight + margin),
            left: 0,
            behavior: "smooth",
          });
        }
      }

      function applyActive() {
        pairs.forEach((pair, idx) => {
          pair.link.classList.toggle("visible", idx === activeIndex);
        });
        updateIndicator();
        scrollToActiveEntry();
      }

      function updateActiveState() {
        activeIndex = resolveActiveIndex();
        applyActive();
      }

      function scheduleUpdate() {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(() => {
          scheduled = false;
          updateActiveState();
        });
      }

      function togglePanel() {
        if (isPanelOpen(panel)) {
          closePanel(panel);
        } else {
          openPanel(panel);
          scheduleUpdate();
        }
      }

      function onDocClick(event) {
        if (!isPanelOpen(panel)) return;
        const target = event.target;
        if (!(target instanceof Node)) return;
        if (panel.contains(target) || btn.contains(target)) return;
        closePanel(panel);
      }

      function onKeyDown(event) {
        if (event.key === "Escape") {
          closePanel(panel);
        }
      }

      function onLinkClick(event) {
        const anchor = event
          .composedPath()
          .find((element) => element instanceof HTMLAnchorElement);
        if (!anchor) return;

        event.preventDefault();
        event.stopPropagation();

        const id = decodeURIComponent(anchor.hash?.substring(1) || "");
        const targetElement = document.getElementById(id);

        if (targetElement instanceof HTMLElement) {
          anchorNavTarget = targetElement;
          targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", anchor.hash);
        }

        const idx = pairs.findIndex((pair) => pair.id === id);
        if (idx >= 0) {
          activeIndex = idx;
          applyActive();
        }

        window.setTimeout(() => {
          anchorNavTarget = null;
        }, 800);
      }

      function onScroll() {
        if (anchorNavTarget) return;
        scheduleUpdate();
      }

      function onResize() {
        init();
      }

      btn.addEventListener("click", togglePanel);
      closeBtn.addEventListener("click", togglePanel);
      content.addEventListener("click", onLinkClick, true);
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onResize);
      document.addEventListener("click", onDocClick);
      document.addEventListener("keydown", onKeyDown);

      closePanel(panel);
      scheduleUpdate();

      window.__floatingTocCleanup = function () {
        btn.removeEventListener("click", togglePanel);
        closeBtn.removeEventListener("click", togglePanel);
        content.removeEventListener("click", onLinkClick, true);
        window.removeEventListener("scroll", onScroll);
        window.removeEventListener("resize", onResize);
        document.removeEventListener("click", onDocClick);
        document.removeEventListener("keydown", onKeyDown);
      };
    }

    window.__floatingTocInit = init;

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }

    if (!window.__floatingTocSwupBound) {
      window.__floatingTocSwupBound = true;

      document.addEventListener("swup:contentReplaced", function () {
        window.setTimeout(init, 100);
      });

      if (window.swup?.hooks) {
        window.swup.hooks.on("content:replace", function () {
          window.setTimeout(init, 100);
        });
        window.swup.hooks.on("page:view", function () {
          window.setTimeout(init, 100);
        });
      }

      window.addEventListener("pageshow", function (event) {
        if (event.persisted) window.setTimeout(init, 100);
      });
    }
  })();
</script>


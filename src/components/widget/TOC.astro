---
import type { MarkdownHeading } from "astro";
import { siteConfig } from "../../config/siteConfig";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
  class?: string;
  style?: string;
  headings: MarkdownHeading[];
}

const { headings = [], class: className = "", style } = Astro.props;
const isPostsRoute =
  Astro.url.pathname.includes("/posts/") || headings.length > 0;
const shouldRenderTocWidget = isPostsRoute && headings.length > 0;
const maxLevel = siteConfig.toc.depth;
---

{
  shouldRenderTocWidget && (
    <WidgetLayout
      name={i18n(I18nKey.tableOfContents)}
      id="toc-widget"
      class={className}
      style={style}
    >
      <div class="toc-widget-shell">
        <table-of-contents class="toc-widget group" id="toc" data-max-level={String(maxLevel)}></table-of-contents>
      </div>
    </WidgetLayout>
  )
}

<script define:vars={{ maxLevel }}>
  class TableOfContents extends HTMLElement {
    tocEl = null;
    visibleClass = "visible";
    observer = null;
    anchorNavTarget = null;

    headingIdxMap = new Map();
    headings = [];
    tocEntries = [];
    activeIndicator = null;
    progressTrack = null;
    progressFill = null;
    activeIndex = -1;

    scheduled = false;

    constructor() {
      super();
    }

    getContentRoot = () => {
      return (
        document.querySelector(".custom-md") ||
        document.querySelector(".markdown-content") ||
        document.querySelector(".prose")
      );
    };

    getReadingLineOffset = () => {
      const navbar = document.getElementById("navbar");
      const navHeight = navbar ? navbar.getBoundingClientRect().height : 80;
      return Math.round(navHeight + 16);
    };

    scheduleUpdate = () => {
      if (this.scheduled) return;
      this.scheduled = true;
      requestAnimationFrame(() => {
        this.scheduled = false;
        this.updateActiveState();
      });
    };

    onIntersect = (entries) => {
      if (this.anchorNavTarget) {
        for (const entry of entries) {
          if (entry.isIntersecting && entry.target === this.anchorNavTarget) {
            this.anchorNavTarget = null;
            break;
          }
        }
      }
      this.scheduleUpdate();
    };

    handleScroll = () => {
      this.scheduleUpdate();
    };

    handleResize = () => {
      // Recreate observer so the rootMargin stays aligned with navbar height.
      this.createObserver();
      this.scheduleUpdate();
    };

    cleanup = () => {
      if (this.observer) {
        this.observer.disconnect();
        this.observer = null;
      }

      if (this.tocEl) {
        this.tocEl.removeEventListener("click", this.handleAnchorClick, true);
      }

      window.removeEventListener("scroll", this.handleScroll);
      window.removeEventListener("resize", this.handleResize);

      this.headingIdxMap.clear();
      this.headings = [];
      this.tocEntries = [];
      this.activeIndicator = null;
      this.progressTrack = null;
      this.progressFill = null;
      this.activeIndex = -1;
      this.anchorNavTarget = null;
      this.tocEl = null;
      this.scheduled = false;
    };

    createObserver = () => {
      if (this.observer) {
        this.observer.disconnect();
        this.observer = null;
      }
      if (!this.headings.length) return;

      const offsetTop = this.getReadingLineOffset();
      this.observer = new IntersectionObserver(this.onIntersect, {
        threshold: 0,
        rootMargin: `${-offsetTop}px 0px -70% 0px`,
      });

      this.headings.forEach((heading) => {
        if (heading instanceof HTMLElement) {
          this.observer.observe(heading);
        }
      });
    };

    resolveActiveIndex = () => {
      if (!this.headings.length) return -1;
      const readLine = this.getReadingLineOffset();
      let active = 0;

      for (let i = 0; i < this.headings.length; i += 1) {
        const heading = this.headings[i];
        if (!(heading instanceof HTMLElement)) continue;

        const rect = heading.getBoundingClientRect();
        if (rect.top <= readLine) {
          active = i;
        } else {
          break;
        }
      }

      return active;
    };

    updateIndicator = () => {
      if (!this.tocEl || !this.activeIndicator) return;
      if (this.activeIndex < 0 || this.activeIndex >= this.tocEntries.length) {
        this.activeIndicator.setAttribute("style", "opacity: 0");
        this.progressTrack?.setAttribute("style", "opacity: 0");
        this.progressFill?.setAttribute("style", "opacity: 0");
        return;
      }

      const parentOffset = this.tocEl.getBoundingClientRect().top;
      const scrollOffset = this.tocEl.scrollTop;
      const entryRect = this.tocEntries[this.activeIndex].getBoundingClientRect();
      const top = entryRect.top - parentOffset + scrollOffset;
      const bottom = entryRect.bottom - parentOffset + scrollOffset;

      this.activeIndicator.setAttribute(
        "style",
        `top: ${top}px; height: ${bottom - top}px; opacity: 1`,
      );

      this.updateProgressRail();
    };

    updateProgressRail = () => {
      if (!this.progressTrack || !this.progressFill || this.tocEntries.length === 0) return;

      const firstEntry = this.tocEntries[0];
      const lastEntry = this.tocEntries[this.tocEntries.length - 1];
      const activeEntry = this.tocEntries[this.activeIndex];

      if (!firstEntry || !lastEntry || !activeEntry) {
        this.progressTrack.setAttribute("style", "opacity: 0");
        this.progressFill.setAttribute("style", "opacity: 0");
        return;
      }

      const start = firstEntry.offsetTop + firstEntry.offsetHeight / 2;
      const end = lastEntry.offsetTop + lastEntry.offsetHeight / 2;
      const activeCenter = activeEntry.offsetTop + activeEntry.offsetHeight / 2;
      const trackHeight = Math.max(0, end - start);
      const fillHeight = Math.max(0, activeCenter - start);
      const opacity = trackHeight > 6 ? 1 : 0;

      this.progressTrack.setAttribute(
        "style",
        `top: ${start}px; height: ${trackHeight}px; opacity: ${opacity}`,
      );
      this.progressFill.setAttribute(
        "style",
        `top: ${start}px; height: ${fillHeight}px; opacity: ${opacity}`,
      );
    };

    toggleActiveHeading = (force = false) => {
      this.tocEntries.forEach((entry, idx) => {
        const isActive = idx === this.activeIndex;
        if (force || entry.classList.contains(this.visibleClass) !== isActive) {
          entry.classList.toggle(this.visibleClass, isActive);
        }
      });

      this.updateIndicator();
    };

    scrollToActiveHeading = () => {
      if (this.anchorNavTarget || !this.tocEl) return;
      if (this.activeIndex < 0 || this.activeIndex >= this.tocEntries.length) return;

      const activeEntry = this.tocEntries[this.activeIndex];
      const tocHeight = this.tocEl.clientHeight;
      const margin = 24;

      const entryTop = activeEntry.offsetTop;
      const entryBottom = entryTop + activeEntry.offsetHeight;
      const viewTop = this.tocEl.scrollTop;
      const viewBottom = viewTop + tocHeight;

      if (entryTop < viewTop + margin) {
        this.tocEl.scrollTo({
          top: Math.max(0, entryTop - margin),
          left: 0,
          behavior: "smooth",
        });
      } else if (entryBottom > viewBottom - margin) {
        this.tocEl.scrollTo({
          top: Math.max(0, entryBottom - tocHeight + margin),
          left: 0,
          behavior: "smooth",
        });
      }
    };

    updateActiveState = () => {
      if (!this.tocEntries.length || !this.headings.length) return;
      const nextIndex = this.resolveActiveIndex();
      const hasChanged = nextIndex !== this.activeIndex;
      this.activeIndex = nextIndex;
      this.toggleActiveHeading(hasChanged);
      this.scrollToActiveHeading();
    };

    handleAnchorClick = (event) => {
      const anchor = event
        .composedPath()
        .find((element) => element instanceof HTMLAnchorElement);

      if (anchor) {
        event.preventDefault();

        const id = decodeURIComponent(anchor.hash?.substring(1));
        const targetElement = document.getElementById(id);

        if (targetElement) {
          this.anchorNavTarget =
            targetElement instanceof HTMLElement ? targetElement : null;
          targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", anchor.hash);
        }

        const idx = this.headingIdxMap.get(id);
        if (typeof idx === "number") {
          this.activeIndex = idx;
          this.toggleActiveHeading();
        }
      }
    };

    connectedCallback() {
      const element =
        document.querySelector(".custom-md") ||
        document.querySelector(".prose") ||
        document.querySelector(".markdown-content");
      let initialized = false;
      const tryInit = () => {
        if (!initialized) {
          initialized = true;
          this.init();
        }
      };

      if (element) {
        element.addEventListener("animationend", tryInit, { once: true });
        setTimeout(tryInit, 300);
      } else {
        tryInit();
        setTimeout(tryInit, 300);
      }
    }

    init() {
      this.cleanup();
      this.regenerateTOC();

      this.tocEl = this;
      this.tocEl.addEventListener("click", this.handleAnchorClick, true);

      this.activeIndicator = this.querySelector("#active-indicator");
      this.progressTrack = this.querySelector("#toc-progress-track");
      this.progressFill = this.querySelector("#toc-progress-fill");
      this.tocEntries = Array.from(
        this.querySelectorAll("a[href^='#']"),
      );

      if (this.tocEntries.length === 0) return;

      const contentRoot = this.getContentRoot();
      const filteredEntries = [];
      const filteredHeadings = [];

      this.headingIdxMap.clear();
      this.tocEntries.forEach((entry) => {
        const id = decodeURIComponent(entry.hash?.substring(1));
        const heading = document.getElementById(id);
        if (
          heading instanceof HTMLElement &&
          (!contentRoot || contentRoot.contains(heading))
        ) {
          const idx = filteredHeadings.length;
          filteredEntries.push(entry);
          filteredHeadings.push(heading);
          this.headingIdxMap.set(id, idx);
        } else {
          entry.remove();
        }
      });

      this.tocEntries = filteredEntries;
      this.headings = filteredHeadings;
      this.activeIndex = -1;

      window.addEventListener("scroll", this.handleScroll, { passive: true });
      window.addEventListener("resize", this.handleResize);

      this.createObserver();
      this.scheduleUpdate();
    }

    regenerateTOC(retryCount = 0) {
      const isPostPage =
        window.location.pathname.includes("/posts/") ||
        document.querySelector(".custom-md, .markdown-content, .prose") !== null;
      if (!isPostPage) {
        this.innerHTML = "";
        return;
      }

      const contentRoot = this.getContentRoot();
      const headingSource = contentRoot || document;
      const headings = Array.from(
        headingSource.querySelectorAll("h1, h2, h3, h4, h5, h6"),
      )
        .filter((heading) => heading.id)
        .map((heading) => ({
          depth: parseInt(heading.tagName.substring(1), 10),
          slug: heading.id,
          text: (heading.textContent || "").replace(/#+\s*$/, "").trim(),
        }));

      if (headings.length === 0 && retryCount < 3) {
        setTimeout(() => this.regenerateTOC(retryCount + 1), 120);
        return;
      }
      if (headings.length === 0) {
        this.innerHTML = "";
        return;
      }

      const minDepth = Math.min(...headings.map((heading) => heading.depth));
      let rootHeadingCount = 1;
      const tocHTML = headings
        .filter((heading) => heading.depth < minDepth + maxLevel)
        .map((heading) => {
          const levelOffset = Math.min(Math.max(heading.depth - minDepth, 0), 2);
          const toneClass =
            levelOffset === 0
              ? "toc-entry-text-root"
              : levelOffset === 1
                ? "toc-entry-text-mid"
                : "toc-entry-text-leaf";
          const marker =
            levelOffset === 0
              ? `<span class="toc-marker toc-marker-root">${rootHeadingCount++}</span>`
              : levelOffset === 1
                ? '<span class="toc-marker toc-marker-mid"></span>'
                : '<span class="toc-marker toc-marker-leaf"></span>';

          return `
            <a href="#${heading.slug}" class="toc-entry toc-depth-${levelOffset}">
              <span class="toc-marker-slot toc-shift-${levelOffset}">
                ${marker}
              </span>
              <span class="toc-entry-text ${toneClass}">${heading.text}</span>
            </a>
          `;
        })
        .join("");

      this.innerHTML =
        tocHTML +
        '<div id="toc-progress-track" style="opacity: 0" class="toc-progress-track"></div>' +
        '<div id="toc-progress-fill" style="opacity: 0" class="toc-progress-fill"></div>' +
        '<div id="active-indicator" style="opacity: 0" class="toc-active-indicator"></div>';
    }

    disconnectedCallback() {
      this.cleanup();
    }
  }

  if (!customElements.get("table-of-contents")) {
    customElements.define("table-of-contents", TableOfContents);
  }
</script>

<style>
  .toc-widget-shell {
    position: relative;
  }

  :global(table-of-contents.toc-widget) {
    position: relative;
    display: flex;
    max-height: calc(100vh - var(--navbar-clearance) - 2rem);
    flex-direction: column;
    gap: 0.35rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding-right: 0.2rem;
    scroll-behavior: smooth;
  }

  :global(table-of-contents.toc-widget::-webkit-scrollbar) {
    width: 4px;
  }

  :global(table-of-contents.toc-widget::-webkit-scrollbar-track) {
    background: transparent;
  }

  :global(table-of-contents.toc-widget::-webkit-scrollbar-thumb) {
    border-radius: 9999px;
    background: color-mix(in srgb, var(--primary) 28%, transparent);
  }

  :global(table-of-contents.toc-widget .toc-entry) {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
    align-items: flex-start;
    gap: 0.75rem;
    border-radius: 1rem;
    padding: 0.7rem 0.75rem;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  :global(table-of-contents.toc-widget .toc-entry:hover) {
    background: color-mix(in srgb, var(--primary) 8%, var(--btn-plain-bg-hover));
  }

  :global(table-of-contents.toc-widget .toc-entry.visible) {
    color: var(--primary);
    transform: translateX(3px);
  }

  :global(table-of-contents.toc-widget .toc-marker-slot) {
    display: flex;
    min-height: 1.5rem;
    width: 1.5rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
  }

  :global(table-of-contents.toc-widget .toc-shift-1) {
    margin-left: 0.85rem;
  }

  :global(table-of-contents.toc-widget .toc-shift-2) {
    margin-left: 1.7rem;
  }

  :global(table-of-contents.toc-widget .toc-marker) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      opacity 180ms ease;
  }

  :global(table-of-contents.toc-widget .toc-marker-root) {
    height: 1.5rem;
    width: 1.5rem;
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--primary) 16%, transparent);
    color: var(--primary);
    font-size: 0.72rem;
    font-weight: 800;
  }

  :global(table-of-contents.toc-widget .toc-marker-mid) {
    height: 0.48rem;
    width: 0.48rem;
    background: color-mix(in srgb, var(--primary) 76%, transparent);
  }

  :global(table-of-contents.toc-widget .toc-marker-leaf) {
    height: 0.36rem;
    width: 0.36rem;
    background: color-mix(in srgb, currentColor 30%, transparent);
    opacity: 0.75;
  }

  :global(table-of-contents.toc-widget .toc-entry-text) {
    min-width: 0;
    flex: 1;
    line-height: 1.45;
    word-break: break-word;
  }

  :global(table-of-contents.toc-widget .toc-entry-text-root) {
    font-size: 0.9rem;
    font-weight: 700;
    color: rgb(23 23 23 / 0.9);
  }

  :global(.dark table-of-contents.toc-widget .toc-entry-text-root) {
    color: rgb(245 245 245 / 0.92);
  }

  :global(table-of-contents.toc-widget .toc-entry-text-mid) {
    font-size: 0.845rem;
    font-weight: 600;
    color: rgb(38 38 38 / 0.78);
  }

  :global(.dark table-of-contents.toc-widget .toc-entry-text-mid) {
    color: rgb(229 229 229 / 0.8);
  }

  :global(table-of-contents.toc-widget .toc-entry-text-leaf) {
    font-size: 0.8rem;
    color: rgb(64 64 64 / 0.66);
  }

  :global(.dark table-of-contents.toc-widget .toc-entry-text-leaf) {
    color: rgb(212 212 212 / 0.68);
  }

  :global(table-of-contents.toc-widget .toc-entry.visible .toc-marker-root) {
    background: var(--primary);
    color: white;
    box-shadow: 0 10px 20px color-mix(in srgb, var(--primary) 18%, transparent);
  }

  :global(table-of-contents.toc-widget .toc-entry.visible .toc-marker-mid),
  :global(table-of-contents.toc-widget .toc-entry.visible .toc-marker-leaf) {
    transform: scale(1.15);
    background: var(--primary);
    opacity: 1;
  }

  :global(table-of-contents.toc-widget .toc-active-indicator) {
    position: absolute;
    left: 0;
    right: 0;
    z-index: 1;
    border: 1px dashed color-mix(in srgb, var(--primary) 24%, transparent);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--primary) 9%, transparent);
    transition:
      top 180ms ease,
      height 180ms ease,
      opacity 180ms ease;
    pointer-events: none;
  }

  :global(table-of-contents.toc-widget .toc-progress-track),
  :global(table-of-contents.toc-widget .toc-progress-fill) {
    position: absolute;
    left: 1.48rem;
    width: 2px;
    border-radius: 9999px;
    pointer-events: none;
    transition:
      top 180ms ease,
      height 180ms ease,
      opacity 180ms ease;
  }

  :global(table-of-contents.toc-widget .toc-progress-track) {
    z-index: 0;
    background: color-mix(in srgb, currentColor 12%, transparent);
  }

  :global(table-of-contents.toc-widget .toc-progress-fill) {
    z-index: 1;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--primary) 72%, white),
      var(--primary)
    );
    box-shadow: 0 0 18px color-mix(in srgb, var(--primary) 18%, transparent);
  }
</style>

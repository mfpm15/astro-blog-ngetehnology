---
import type { MarkdownHeading } from "astro";
import type { WidgetComponentConfig } from "../../types/config";
import { widgetManager } from "../../utils/widget-manager";
import Announcement from "./Announcement.astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import Tags from "./Tags.astro";
import TOC from "./TOC.astro";
import Advertisement from "./Advertisement.astro";
import Calendar from "./Calendar.astro";
import MusicPlayer from "./MusicPlayer.svelte";
import SiteStats from "./SiteStats.astro";

interface Props {
  class?: string;
  headings?: MarkdownHeading[];
  side?: "left" | "right";
  isPostPage?: boolean;
}

const { class: className, headings, side = "left", isPostPage = false } = Astro.props;

const topComponents = widgetManager.getComponentsByPosition("top", side, isPostPage);
const stickyComponents = widgetManager.getComponentsByPosition("sticky", side, isPostPage);
// Firefly parity: right rail should keep sticky utilities (stats/toc) above scrollable widgets (calendar).
const renderStickyFirst = side === "right";

const sidebarConfig = {
  breakpoints: widgetManager.getBreakpoints(),
  shouldShowSidebar: {
    mobile: widgetManager.shouldShowSidebarSide("mobile", side, isPostPage),
    tablet: widgetManager.shouldShowSidebarSide("tablet", side, isPostPage),
    desktop: widgetManager.shouldShowSidebarSide("desktop", side, isPostPage),
  },
  side,
};

const componentMap = {
  profile: Profile,
  announcement: Announcement,
  categories: Categories,
  tags: Tags,
  toc: TOC,
  sidebarToc: TOC,
  advertisement: Advertisement,
  calendar: Calendar,
  stats: SiteStats,
  "site-stats": SiteStats,
  music: MusicPlayer,
  "music-player": MusicPlayer,
};

type RenderData = {
  Component: any;
  props: Record<string, unknown>;
};

function renderComponent(component: WidgetComponentConfig, index: number): RenderData | null {
  const ComponentToRender = componentMap[component.type as keyof typeof componentMap];
  if (!ComponentToRender) return null;

  const props: Record<string, unknown> = {
    class: widgetManager.getComponentClass(component, index),
    style: widgetManager.getComponentStyle(component, index),
    componentConfig: component,
    configId: component.configId,
    ...component.customProps,
  };

  if ((component.type === "toc" || component.type === "sidebarToc") && headings) {
    props.headings = headings;
  }

  return {
    Component: ComponentToRender as any,
    props,
  };
}
---

<div id={`sidebar-${side}`} class:list={[className, "w-full"]}>
  {
    renderStickyFirst &&
      stickyComponents.length > 0 && (
        <div
          id={`sidebar-sticky-${side}`}
          class:list={[
            "sticky top-[var(--navbar-clearance)] flex w-full flex-col gap-4 transition-all duration-700",
            topComponents.length > 0 && "mb-4",
          ]}
        >
          {stickyComponents.map((component, index) => {
            const renderData = renderComponent(component, index);
            if (!renderData) return null;

            const { Component, props } = renderData;
            return <Component {...props} />;
          })}
        </div>
      )
  }

  {
    topComponents.length > 0 && (
      <div class="mb-4 flex w-full flex-col gap-4">
        {topComponents.map((component, index) => {
          const renderData = renderComponent(component, index);
          if (!renderData) return null;

          const { Component, props } = renderData;
          return <Component {...props} />;
        })}
      </div>
    )
  }

  {
    !renderStickyFirst &&
      stickyComponents.length > 0 && (
        <div
          id={`sidebar-sticky-${side}`}
          class="sticky top-[var(--navbar-clearance)] flex w-full flex-col gap-4 transition-all duration-700"
        >
          {stickyComponents.map((component, index) => {
            const renderData = renderComponent(component, index);
            if (!renderData) return null;

            const { Component, props } = renderData;
            return <Component {...props} />;
          })}
        </div>
      )
  }
</div>

<script define:vars={{ sidebarConfig }}>
  class SidebarManager {
    constructor() {
      this.config = sidebarConfig;
      this.handleResize = this.updateResponsiveDisplay.bind(this);
      this.init();
    }

    init() {
      this.updateResponsiveDisplay();
      window.addEventListener("resize", this.handleResize);
      document.addEventListener("astro:after-swap", this.handleResize);
    }

    destroy() {
      window.removeEventListener("resize", this.handleResize);
      document.removeEventListener("astro:after-swap", this.handleResize);
    }

    updateResponsiveDisplay() {
      const breakpoints = this.config.breakpoints;
      const width = window.innerWidth;

      let deviceType;
      if (width < breakpoints.mobile) {
        deviceType = "mobile";
      } else if (width < breakpoints.tablet) {
        deviceType = "tablet";
      } else {
        deviceType = "desktop";
      }

      const sidebar = document.getElementById(`sidebar-${this.config.side}`);
      if (!sidebar) return;

      sidebar.style.display = this.config.shouldShowSidebar[deviceType] ? "block" : "none";
    }
  }

  window.__sidebarManagers ??= {};
  window.__sidebarManagers[sidebarConfig.side]?.destroy?.();
  window.__sidebarManagers[sidebarConfig.side] = new SidebarManager();
</script>

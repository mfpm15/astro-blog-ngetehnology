---
export interface Props {
  text: string | string[];
  speed?: number;
  deleteSpeed?: number;
  pauseTime?: number;
  class?: string;
}

const {
  text,
  speed = 100,
  deleteSpeed = 50,
  pauseTime = 2000,
  class: className = "",
} = Astro.props;
const textData = Array.isArray(text) ? JSON.stringify(text) : text;
const initialText =
  Array.isArray(text)
    ? text.find((entry) => typeof entry === "string" && entry.trim()) ?? ""
    : text;
---

<span
  class={`typewriter ${className}`}
  data-text={textData}
  data-speed={speed}
  data-delete-speed={deleteSpeed}
  data-pause-time={pauseTime}>{initialText}</span>

<script>
  type TypewriterElement = HTMLElement & {
    __typewriterInstance?: TypewriterEffect;
  };

  type TypewriterWindow = Window & {
    __ngetehTypewriterBound?: boolean;
    __ngetehTypewriterRetry?: number | null;
    __ngetehTypewriterTimers?: Set<number>;
    __ngetehTypewriterInit?: (options?: { resetText?: boolean; retry?: boolean; attempt?: number }) => void;
    __ngetehTypewriterCleanup?: (resetText?: boolean) => void;
  };

  const typewriterWindow = window as TypewriterWindow;
  const trackedTimers =
    typewriterWindow.__ngetehTypewriterTimers ||
    (typewriterWindow.__ngetehTypewriterTimers = new Set<number>());

  class TypewriterEffect {
    private element: TypewriterElement;
    private texts: string[];
    private currentTextIndex = 0;
    private speed: number;
    private deleteSpeed: number;
    private pauseTime: number;
    private currentIndex = 0;
    private isDeleting = false;
    private timeoutId: number | null = null;

    constructor(element: TypewriterElement) {
      this.element = element;
      const textData = element.dataset.text || "";

      try {
        const parsed = JSON.parse(textData);
        this.texts = Array.isArray(parsed) ? parsed : [textData];
      } catch {
        this.texts = [textData];
      }

      this.speed = parseInt(element.dataset.speed || "100", 10);
      this.deleteSpeed = parseInt(element.dataset.deleteSpeed || "50", 10);
      this.pauseTime = parseInt(element.dataset.pauseTime || "2000", 10);

      if (this.texts.length > 1 && !this.isTypewriterEnabled()) {
        this.showRandomText();
      } else {
        this.start();
      }
    }

    private isTypewriterEnabled(): boolean {
      return (
        this.element.dataset.speed !== undefined ||
        this.element.dataset.deleteSpeed !== undefined ||
        this.element.dataset.pauseTime !== undefined
      );
    }

    private showRandomText() {
      const randomIndex = Math.floor(Math.random() * this.texts.length);
      this.element.textContent = this.texts[randomIndex];
    }

    private start() {
      if (this.texts.length === 0) return;
      this.type();
    }

    private getCurrentText(): string {
      return this.texts[this.currentTextIndex] || "";
    }

    private segmentText(text: string): string[] {
      if (typeof Intl !== "undefined" && "Segmenter" in Intl) {
        const segmenter = new Intl.Segmenter(undefined, {
          granularity: "grapheme",
        });
        return Array.from(segmenter.segment(text), (segment) => segment.segment);
      }

      return Array.from(text);
    }

    private clearScheduledStep() {
      if (this.timeoutId !== null) {
        clearTimeout(this.timeoutId);
        trackedTimers.delete(this.timeoutId);
      }

      this.timeoutId = null;
    }

    private scheduleNextStep(delay: number) {
      this.clearScheduledStep();
      this.timeoutId = window.setTimeout(() => this.type(), delay);
      trackedTimers.add(this.timeoutId);
    }

    private type() {
      const currentText = this.getCurrentText();
      const segments = this.segmentText(currentText);

      if (this.isDeleting) {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.element.textContent = segments.slice(0, this.currentIndex).join("");
          this.scheduleNextStep(this.deleteSpeed);
        } else {
          this.isDeleting = false;
          this.currentTextIndex = (this.currentTextIndex + 1) % this.texts.length;
          this.scheduleNextStep(this.speed);
        }
      } else if (this.currentIndex < segments.length) {
        this.currentIndex++;
        this.element.textContent = segments.slice(0, this.currentIndex).join("");
        this.scheduleNextStep(this.speed);
      } else if (this.texts.length > 1) {
        this.isDeleting = true;
        this.scheduleNextStep(this.pauseTime);
      }
    }

    public destroy(resetText: boolean = false) {
      this.clearScheduledStep();

      if (resetText) {
        this.element.textContent = "";
      }
    }
  }

  function isTypewriterVisible(element: TypewriterElement): boolean {
    const homeOverlay = element.closest(".banner-home-text-overlay");
    if (!(homeOverlay instanceof HTMLElement)) {
      return true;
    }

    const bannerWrapper = homeOverlay.closest("#banner-wrapper");
    const heroMode = bannerWrapper?.getAttribute("data-hero-mode");
    const isHidden =
      homeOverlay.classList.contains("hidden") ||
      homeOverlay.getAttribute("aria-hidden") === "true";

    if (heroMode && heroMode !== "home") {
      return false;
    }

    return !isHidden;
  }

  function clearTrackedTimeouts() {
    trackedTimers.forEach((timerId) => {
      clearTimeout(timerId);
    });
    trackedTimers.clear();
  }

  function destroyTypewriters(resetText: boolean = false) {
    const typewriterElements =
      document.querySelectorAll<TypewriterElement>(".typewriter");

    typewriterElements.forEach((element) => {
      element.__typewriterInstance?.destroy(resetText);
      delete element.__typewriterInstance;
    });

    clearTrackedTimeouts();
  }

  function isHomeRoute(): boolean {
    return window.location.pathname === "/" || window.location.pathname === "";
  }

  function syncHomeOverlayState() {
    if (!isHomeRoute()) return;

    const homeOverlay = document.querySelector(".banner-home-text-overlay");
    const bannerWrapper = document.getElementById("banner-wrapper");
    const contentShell = document.getElementById("content-shell");

    if (bannerWrapper) {
      bannerWrapper.setAttribute("data-hero-mode", "home");
      bannerWrapper.setAttribute("data-page-kind", "home");
    }

    if (contentShell) {
      contentShell.setAttribute("data-hero-mode", "home");
      contentShell.setAttribute("data-page-kind", "home");
    }

    if (homeOverlay instanceof HTMLElement) {
      homeOverlay.classList.remove("hidden");
      homeOverlay.setAttribute("aria-hidden", "false");
    }
  }

  function clearTypewriterRetry() {
    if (typewriterWindow.__ngetehTypewriterRetry !== null && typewriterWindow.__ngetehTypewriterRetry !== undefined) {
      clearTimeout(typewriterWindow.__ngetehTypewriterRetry);
      typewriterWindow.__ngetehTypewriterRetry = null;
    }
  }

  function initTypewriters(options: { resetText?: boolean } = {}) {
    syncHomeOverlayState();

    const typewriterElements =
      document.querySelectorAll<TypewriterElement>(".typewriter");

    if (options.resetText) {
      destroyTypewriters(true);
    }

    typewriterElements.forEach((element) => {
      element.__typewriterInstance?.destroy(true);

      if (!isTypewriterVisible(element)) {
        delete element.__typewriterInstance;
        return;
      }

      element.__typewriterInstance = new TypewriterEffect(element);
    });
  }

  function queueTypewriterInit(options: { resetText?: boolean; retry?: boolean; attempt?: number } = {}) {
    clearTypewriterRetry();

    window.requestAnimationFrame(() => {
      initTypewriters(options);

      if (!options.retry || !isHomeRoute()) return;

      const typewriterElements =
        document.querySelectorAll<TypewriterElement>(".banner-home-text-overlay .typewriter");
      const hasRunningTypewriter = Array.from(typewriterElements).some(
        (element) => element.__typewriterInstance,
      );

      const attempt = options.attempt ?? 0;
      if ((typewriterElements.length === 0 || !hasRunningTypewriter) && attempt < 12) {
        typewriterWindow.__ngetehTypewriterRetry = window.setTimeout(() => {
          queueTypewriterInit({ resetText: true, retry: true, attempt: attempt + 1 });
        }, 120);
      }
    });
  }

  typewriterWindow.__ngetehTypewriterInit = (options = {}) => {
    queueTypewriterInit(options);
  };
  typewriterWindow.__ngetehTypewriterCleanup = (resetText = false) => {
    destroyTypewriters(resetText);
  };

  if (!typewriterWindow.__ngetehTypewriterBound) {
    typewriterWindow.__ngetehTypewriterBound = true;

    document.addEventListener("DOMContentLoaded", queueTypewriterInit);
    document.addEventListener("swup:contentReplaced", queueTypewriterInit);
    document.addEventListener("swup:content:replace", queueTypewriterInit);
    document.addEventListener("swup:page:view", queueTypewriterInit);
    window.addEventListener("pageshow", () => {
      queueTypewriterInit({ resetText: isHomeRoute(), retry: true });
    });
    window.addEventListener("popstate", () => {
      queueTypewriterInit({ resetText: isHomeRoute(), retry: true });
    });
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        queueTypewriterInit({ retry: true });
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", queueTypewriterInit, {
      once: true,
    });
  } else {
    queueTypewriterInit();
  }
</script>

<style>
  .typewriter {
    position: relative;
  }

  .typewriter::after {
    content: "|";
    animation: blink 1s infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }
</style>

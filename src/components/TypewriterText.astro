---
export interface Props {
  text: string | string[];
  speed?: number;
  deleteSpeed?: number;
  pauseTime?: number;
  class?: string;
}

const {
  text,
  speed = 100,
  deleteSpeed = 50,
  pauseTime = 2000,
  class: className = "",
} = Astro.props;
const textData = Array.isArray(text) ? JSON.stringify(text) : text;
const initialText =
  Array.isArray(text)
    ? text.find((entry) => typeof entry === "string" && entry.trim()) ?? ""
    : text;
---

<span
  class={`typewriter ${className}`}
  data-text={textData}
  data-speed={speed}
  data-delete-speed={deleteSpeed}
  data-pause-time={pauseTime}>{initialText}</span>

<script>
  type TypewriterElement = HTMLElement & {
    __typewriterInstance?: TypewriterEffect;
  };

  class TypewriterEffect {
    private element: TypewriterElement;
    private texts: string[];
    private currentTextIndex = 0;
    private speed: number;
    private deleteSpeed: number;
    private pauseTime: number;
    private currentIndex = 0;
    private isDeleting = false;
    private timeoutId: number | null = null;

    constructor(element: TypewriterElement) {
      this.element = element;
      const textData = element.dataset.text || "";

      try {
        const parsed = JSON.parse(textData);
        this.texts = Array.isArray(parsed) ? parsed : [textData];
      } catch {
        this.texts = [textData];
      }

      this.speed = parseInt(element.dataset.speed || "100", 10);
      this.deleteSpeed = parseInt(element.dataset.deleteSpeed || "50", 10);
      this.pauseTime = parseInt(element.dataset.pauseTime || "2000", 10);

      if (this.texts.length > 1 && !this.isTypewriterEnabled()) {
        this.showRandomText();
      } else {
        this.start();
      }
    }

    private isTypewriterEnabled(): boolean {
      return (
        this.element.dataset.speed !== undefined ||
        this.element.dataset.deleteSpeed !== undefined ||
        this.element.dataset.pauseTime !== undefined
      );
    }

    private showRandomText() {
      const randomIndex = Math.floor(Math.random() * this.texts.length);
      this.element.textContent = this.texts[randomIndex];
    }

    private start() {
      if (this.texts.length === 0) return;
      this.type();
    }

    private getCurrentText(): string {
      return this.texts[this.currentTextIndex] || "";
    }

    private segmentText(text: string): string[] {
      if (typeof Intl !== "undefined" && "Segmenter" in Intl) {
        const segmenter = new Intl.Segmenter(undefined, {
          granularity: "grapheme",
        });
        return Array.from(segmenter.segment(text), (segment) => segment.segment);
      }

      return Array.from(text);
    }

    private type() {
      const currentText = this.getCurrentText();
      const segments = this.segmentText(currentText);

      if (this.isDeleting) {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.element.textContent = segments.slice(0, this.currentIndex).join("");
          this.timeoutId = window.setTimeout(() => this.type(), this.deleteSpeed);
        } else {
          this.isDeleting = false;
          this.currentTextIndex = (this.currentTextIndex + 1) % this.texts.length;
          this.timeoutId = window.setTimeout(() => this.type(), this.speed);
        }
      } else if (this.currentIndex < segments.length) {
        this.currentIndex++;
        this.element.textContent = segments.slice(0, this.currentIndex).join("");
        this.timeoutId = window.setTimeout(() => this.type(), this.speed);
      } else if (this.texts.length > 1) {
        this.isDeleting = true;
        this.timeoutId = window.setTimeout(() => this.type(), this.pauseTime);
      }
    }

    public destroy(resetText: boolean = false) {
      if (this.timeoutId) {
        clearTimeout(this.timeoutId);
      }

      this.timeoutId = null;

      if (resetText) {
        this.element.textContent = "";
      }
    }
  }

  function isTypewriterVisible(element: TypewriterElement): boolean {
    const homeOverlay = element.closest(".banner-home-text-overlay");
    if (!(homeOverlay instanceof HTMLElement)) {
      return true;
    }

    const bannerWrapper = homeOverlay.closest("#banner-wrapper");
    const heroMode = bannerWrapper?.getAttribute("data-hero-mode");
    const isHidden =
      homeOverlay.classList.contains("hidden") ||
      homeOverlay.getAttribute("aria-hidden") === "true";

    if (heroMode && heroMode !== "home") {
      return false;
    }

    return !isHidden;
  }

  function initTypewriters() {
    const typewriterElements =
      document.querySelectorAll<TypewriterElement>(".typewriter");

    typewriterElements.forEach((element) => {
      element.__typewriterInstance?.destroy(true);

      if (!isTypewriterVisible(element)) {
        delete element.__typewriterInstance;
        return;
      }

      element.__typewriterInstance = new TypewriterEffect(element);
    });
  }

  function queueTypewriterInit() {
    window.requestAnimationFrame(() => {
      initTypewriters();
    });
  }

  const typewriterWindow = window as Window & {
    __ngetehTypewriterBound?: boolean;
  };

  if (!typewriterWindow.__ngetehTypewriterBound) {
    typewriterWindow.__ngetehTypewriterBound = true;

    document.addEventListener("DOMContentLoaded", queueTypewriterInit);
    document.addEventListener("swup:contentReplaced", queueTypewriterInit);
    document.addEventListener("swup:content:replace", queueTypewriterInit);
    document.addEventListener("swup:page:view", queueTypewriterInit);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", queueTypewriterInit, {
      once: true,
    });
  } else {
    queueTypewriterInit();
  }
</script>

<style>
  .typewriter {
    position: relative;
  }

  .typewriter::after {
    content: "|";
    animation: blink 1s infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }
</style>
